---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Locking Wheel Nut Removal',
  serviceType: 'Mobile Locking Wheel Nut Removal',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Tyre Emergency Ltd',
    telephone: '+441623325123',
    url: 'https://tyreemergencyltd.co.uk/',
  },
  areaServed: 'Nottinghamshire, East Midlands',
  description: 'On-site removal of damaged, seized or missing-key locking wheel nuts using non-destructive extraction tools.',
  url: 'https://tyreemergencyltd.co.uk/services/locking-wheel-nut-removal/',
};
---

<BaseLayout
  title="Locking Wheel Nut Removal Nottinghamshire | Lost Key, Seized Nuts"
  description="Mobile locking wheel nut removal across Nottinghamshire. Lost keys, stripped patterns, seized nuts &mdash; we deal with all of them, on your driveway or at the garage. Specialist extraction tools, minimal wheel damage, fast turnaround. Get an instant price online or call 01623 325 123."
  jsonLd={JSON.stringify(serviceJsonLd)}
>
  <HeroSection
    eyebrow="Specialist Extraction · Nottinghamshire"
    title="Locking Wheel Nut Removal"
    subtitle="Lost the key, stripped the pattern, seized on the stud &mdash; we get them off. Most jobs sorted in 15&ndash;30 minutes."
    ctaPhone={phone}
    ctaCallLabel="Call for a price"
    secondaryCta={{ label: 'Get an instant price', href: '/quote/?service=lwnr' }}
    bgImage="/images/locking-wheel-nut-removal.webp"
    bgImageAlt="Close-up of a stripped locking wheel nut being extracted on an alloy wheel"
    trustItems={[
      { strong: '478', label: '★★★★★ Google reviews' },
      { strong: 'Specialist', label: 'extraction kit on the van' },
      { strong: '15–30 min', label: 'typical job time' },
    ]}
  />
  <section class="section section-white">
    <div class="container">
      <div class="service-split">
        <div class="service-split-image">
          <img
            src="/images/locking-wheel-nut-removal.webp"
            alt="Close-up of a severely stripped and damaged locking wheel nut on an alloy wheel"
            width="1182"
            height="665"
            loading="lazy"
          />
        </div>
        <div class="service-split-content">
          <span class="eyebrow">What we do</span>
          <h2>Built for this exact job</h2>
          <ul class="check-list">
            <li><strong>Every type of locker, every make of car.</strong> Lost keys, stripped patterns, snapped keys, seized nuts, slipping keys &mdash; we&rsquo;ve come across yours before and we carry the kit to handle it.</li>
            <li><strong>A range of specialist extraction kits on the van.</strong> Not a one-size-fits-all gadget &mdash; a proper set of professional extractors so we&rsquo;ve got the right tool for whatever&rsquo;s on the wheel when we get there.</li>
            <li><strong>Fast on the driveway.</strong> Most jobs are 15&ndash;30 minutes door-to-door once we&rsquo;re with you. Same-day slots most days of the week.</li>
            <li><strong>Replacement nut fitted to spec.</strong> Once the locker is out, a standard nut goes on, torqued to the manufacturer&rsquo;s figure, so the wheel is safe to drive on the moment we hand the keys back.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container container-narrow">
      <span class="eyebrow">When You Need This</span>
      <h2>The kind of situations we get called for</h2>
      <div class="scenarios">
        <article class="scenario">
          <h3>Booked in for tyres and the locker key is missing</h3>
          <p>You&rsquo;ve gone to get tyres or other work done and only then realised the key isn&rsquo;t in the car. Without it, no garage will touch the wheel and the job stalls. We come out, get the locker off, and the rest of the work can carry on.</p>
        </article>
        <article class="scenario">
          <h3>Stripped or rounded locking nut</h3>
          <p>A previous garage has put an air gun on the locker and chewed the pattern. The key now spins freely. Our extractors are made for exactly this &mdash; we&rsquo;ll have it out and a standard nut back on.</p>
        </article>
        <article class="scenario">
          <h3>Stuck at a garage, can&rsquo;t move on</h3>
          <p>Your car&rsquo;s sitting on a ramp somewhere and the whole job is paused waiting on a locking nut. We&rsquo;ll come to the garage, get it sorted, and let them carry on.</p>
        </article>
        <article class="scenario">
          <h3>Seized lock, key intact</h3>
          <p>The key still fits but the nut won&rsquo;t move &mdash; corroded onto the stud after a few winters of salt. We can usually heat, penetrate and turn it without going to full extraction.</p>
        </article>
      </div>
    </div>
  </section>


  <ReviewsSection />

  <section class="section section-white service-cta-section">
    <div class="container container-narrow text-center">
      <span class="eyebrow">Instant price</span>
      <h2>Get a price for your locking nut job</h2>
      <p class="text-muted-dark">A few quick questions about your postcode and how many lockers need removing and we&rsquo;ll show you a price on the spot. Book a slot in the same flow.</p>
      <div class="cta-row" style="justify-content: center;">
        <a class="btn btn-primary" href="/quote/?service=lwnr">Get an instant price</a>
        <a class="btn btn-outline-dark btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Or call: {phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

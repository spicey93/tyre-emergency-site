---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Mobile Caravan Tyre Fitting',
  serviceType: 'Mobile Caravan and Motorhome Tyre Fitting',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Tyre Emergency Ltd',
    telephone: '+441623325123',
    url: 'https://tyreemergencyltd.co.uk/',
  },
  areaServed: 'Nottinghamshire, East Midlands',
  description: 'On-site tyre fitting and replacement for caravans, motorhomes and trailers across Nottinghamshire and the surrounding counties.',
  url: 'https://tyreemergencyltd.co.uk/services/mobile-caravan-tyre-fitting/',
};
---

<BaseLayout
  title="Mobile Caravan Tyre Fitting Nottinghamshire | Caravans, Motorhomes & Trailers"
  description="Mobile tyre fitting for caravans, motorhomes and trailers across Nottinghamshire. No towing to a tyre shop and no risk of damaged motor movers, Tyron bands or stabilisers. Call 01623 325 123."
  jsonLd={JSON.stringify(serviceJsonLd)}
>
  <HeroSection
    eyebrow="Specialist Service · Nottinghamshire"
    title="Mobile Caravan Tyre Fitting"
    subtitle="We come to your van &mdash; not the other way round. Motor movers and Tyron bands handled with care."
    ctaPhone={phone}
    ctaCallLabel="Call for a price"
    secondaryCta={{ label: 'Get an instant price', href: '/quote/?service=caravan' }}
    bgImage="/images/mobile-caravan-tyre-fitting.jpeg"
    bgImageAlt="Caravan tyre being changed by Tyre Emergency Ltd at the side of the customer's pitch"
    trustItems={[
      { strong: '478', label: '★★★★★ Google reviews' },
      { strong: 'REACT', label: 'licensed & fully insured' },
      { strong: 'Motor movers', label: '& Tyron bands handled with care' },
    ]}
  />
  <section class="section section-white">
    <div class="container">
      <div class="service-split">
        <div class="service-split-image">
          <img
            src="/images/mobile-motorhome-tyre-fitting.jpeg"
            alt="Mobile tyre fitting on a motorhome on a customer's driveway"
            width="2000"
            height="1500"
            loading="lazy"
          />
        </div>
        <div class="service-split-content">
          <span class="eyebrow">Why caravan owners book us</span>
          <h2>Why caravan owners book us in</h2>
          <ul class="check-list">
            <li><strong>No towing the &lsquo;van anywhere</strong> &mdash; we come to your driveway, storage site or pitch and do the lot there. Saves the hitching-up, the diesel and the worry of moving it.</li>
            <li><strong>Motor movers and Tyron bands handled with care</strong> &mdash; we know exactly where they live, where to lift the unit, and what not to lean on. The cheapest tyre shop is rarely worth a damaged motor mover.</li>
            <li><strong>The right tyres sourced to order</strong> &mdash; CP-rated and reinforced sizes for caravans and motorhomes brought with us, matched to the correct load index and speed rating for your unit.</li>
            <li><strong>Torqued to spec, pressures set to laden</strong> &mdash; wheel nuts to the manufacturer&rsquo;s figure, pressures set to the figure on the unit&rsquo;s weight plate. None of this is optional, but it&rsquo;s amazing how often it&rsquo;s missed.</li>
            <li><strong>An honest price up front</strong> &mdash; we&rsquo;ll tell you what it costs over the phone, including the call-out, so there are no surprises when we arrive.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container container-narrow">
      <span class="eyebrow">When You Need This</span>
      <h2>The kind of caravan jobs we get</h2>
      <div class="scenarios">
        <article class="scenario">
          <h3>Pre-season age replacement</h3>
          <p>Your caravan tyres are five or more years old. Even with plenty of tread, aged caravan tyres are an insurance and safety issue waiting to happen. We&rsquo;ll come to the driveway or storage site and replace them before the season starts &mdash; no need to drag the &lsquo;van anywhere.</p>
        </article>
        <article class="scenario">
          <h3>Sidewall blowout on tow</h3>
          <p>You&rsquo;ve had a blowout with the caravan on tow and you&rsquo;re sitting in a layby. We&rsquo;ll come to wherever you&rsquo;ve safely pulled over, fit a replacement, and get you back on the road instead of waiting hours for a flatbed.</p>
        </article>
        <article class="scenario">
          <h3>Flat discovered on the pitch</h3>
          <p>You&rsquo;ve arrived at a site, set up, and spotted a flat. We&rsquo;ll come to the campsite, work right on the pitch, and have you sorted without losing a day of the holiday.</p>
        </article>
        <article class="scenario">
          <h3>Horsebox or braked trailer</h3>
          <p>Horseboxes and braked trailers need the right-rated tyre and careful handling. We&rsquo;ve got the experience and can source the sizes for most common configurations.</p>
        </article>
      </div>
    </div>
  </section>

  
  <ReviewsSection />

  <section class="section section-white service-cta-section">
    <div class="container container-narrow text-center">
      <span class="eyebrow">Instant price</span>
      <h2>Caravan or motorhome job?</h2>
      <p class="text-muted-dark">Get a price through the online booking system, or ring with the make, model and tyre size from the sidewall and we&rsquo;ll quote on the spot. The &lsquo;van doesn&rsquo;t move either way.</p>
      <div class="cta-row" style="justify-content: center;">
        <a class="btn btn-primary" href="/quote/?service=caravan">Get an instant price</a>
        <a class="btn btn-outline-dark btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Or call: {phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import { defaultPhone, defaultTelHref, defaultPhoneIntl } from '../../data/business';

const phone = defaultPhone;
const telHref = defaultTelHref;

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Emergency Tyre Replacement',
  serviceType: 'Emergency Mobile Tyre Replacement',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Tyre Emergency Ltd',
    telephone: defaultPhoneIntl,
    url: 'https://tyreemergencyltd.co.uk/',
  },
  areaServed: 'Nottinghamshire, East Midlands',
  description: 'Round-the-clock emergency tyre replacement on the roadside, on the driveway or anywhere in between, across Nottinghamshire and the surrounding counties.',
  url: 'https://tyreemergencyltd.co.uk/services/emergency-tyre-replacement/',
};
---

<BaseLayout
  title="Emergency Tyre Replacement Nottinghamshire | 24/7 Mobile Service"
  description={`24/7 emergency mobile tyre replacement across Nottinghamshire. Exact price over the phone, realistic ETA, and everything on the van to get you back on the road first time. Call ${phone}.`}
  jsonLd={JSON.stringify(serviceJsonLd)}
>
  <HeroSection
    eyebrow="24/7 Emergency Service · Nottinghamshire"
    title="Emergency Tyre Replacement"
    subtitle="Stuck with a flat? We come to you, fit a new tyre on the spot, and get you moving."
    ctaPhone={phone}
    ctaCallLabel="Call 24/7"
    bgImage="/images/flat-tyre-roadside.webp"
    bgImageAlt="Tyre Emergency Ltd service van and traffic cones at the roadside next to a customer's car with a flat tyre"
  />

  <ReviewsSection variant="light" />

  <section class="section section-white">
    <div class="container">
      <div class="service-split">
        <div class="service-split-image">
          <img
            src="/images/roadside-tyre-change.jpeg"
            alt="Tyre being changed at the roadside next to the Tyre Emergency Ltd service van"
            width="2000"
            height="1500"
            loading="lazy"
          />
        </div>
        <div class="service-split-content">
          <span class="eyebrow">How it works</span>
          <h2>Built to be fast and streamlined</h2>
          <ul class="check-list">
            <li><strong>An exact price over the phone</strong> &mdash; you&rsquo;ll know what you&rsquo;re paying before we set off, with no hidden costs or extras tacked on when we arrive.</li>
            <li><strong>A realistic ETA, not a best-case one</strong> &mdash; we tell you when we&rsquo;ll genuinely be with you so you can plan around it.</li>
            <li><strong>Don&rsquo;t know exactly where you are?</strong> We&rsquo;ll send you a quick text and pick up your location from your phone &mdash; no postcode-guessing on either side.</li>
            <li><strong>Everything we need is on the van</strong> &mdash; the right tyre sourced before we leave, balancer, torque wrench and disposal sorted, so you&rsquo;re back on the road first time.</li>
            <li><strong>Friendly, experienced and unflustered</strong> &mdash; you&rsquo;ll be talking to someone who has done this thousands of times and won&rsquo;t make a stressful day worse.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container container-narrow">
      <span class="eyebrow">When You Need This</span>
      <h2>The kind of calls we get every day</h2>
      <p>If any of these sound like you, just give us a ring &mdash; we&rsquo;ve been there before and we&rsquo;ll get you moving.</p>
      <div class="scenarios">
        <article class="scenario">
          <h3>Blowout on the way to the airport</h3>
          <p>Suitcases packed, flight booked, and a tyre lets go on the dual carriageway. We&rsquo;ll be on our way within minutes and have a new tyre fitted on the spot &mdash; usually quicker than waiting for recovery to even arrive.</p>
        </article>
        <article class="scenario">
          <h3>Flat on the driveway before the school run</h3>
          <p>You&rsquo;ve walked out at 7:45am to find a tyre on the deck. Phone us, get a fixed price, and we&rsquo;ll do everything we can to have you sorted before you need to be anywhere.</p>
        </article>
        <article class="scenario">
          <h3>Stranded somewhere remote</h3>
          <p>Country lane, layby, supermarket car park &mdash; if you don&rsquo;t know exactly where you are, we&rsquo;ll send you a text to grab your location, then come straight to you.</p>
        </article>
        <article class="scenario">
          <h3>Kerbed wheel with a split tyre</h3>
          <p>You&rsquo;ve clipped a kerb and cracked the tyre internally. Often invisible from outside but not safe to drive on. We&rsquo;ll fit a new one wherever you&rsquo;ve stopped.</p>
        </article>
      </div>
    </div>
  </section>

  
  <section class="section section-white service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Stuck right now?</h2>
      <p class="text-muted-dark">Pick up the phone &mdash; we answer 24/7 and we&rsquo;ll have a price, an honest ETA and a van on the way within minutes.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>


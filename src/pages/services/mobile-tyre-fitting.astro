---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Mobile Tyre Fitting',
  serviceType: 'Pre-booked Mobile Tyre Fitting',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Tyre Emergency Ltd',
    telephone: '+441623325123',
    url: 'https://tyreemergencyltd.co.uk/',
  },
  areaServed: 'Nottinghamshire, East Midlands',
  description: 'Pre-booked mobile tyre fitting at your home, workplace or anywhere else convenient, across Nottinghamshire and the surrounding counties.',
  url: 'https://tyreemergencyltd.co.uk/services/mobile-tyre-fitting/',
};
---

<BaseLayout
  title="Mobile Tyre Fitting Nottinghamshire | We Come To You"
  description="Mobile tyre fitting at your home or workplace across Nottinghamshire. Everything a tyre shop does &mdash; properly fitted, balanced and torqued &mdash; without you having to drive anywhere. Call 01623 325 123."
  jsonLd={JSON.stringify(serviceJsonLd)}
>
  <HeroSection
    eyebrow="Pre-booked Service · Nottinghamshire"
    title="Mobile Tyre Fitting"
    subtitle="Everything a tyre shop does, done on your driveway. No waiting room, no half-day off work."
    ctaPhone={phone}
    ctaCallLabel="Call for a price"
    secondaryCta={{ label: 'Get an instant price', href: '/quote/?service=mobile-fitting' }}
    bgImage="/images/mobile-tyre-fitting.webp"
    bgImageAlt="Tyre being fitted on a car wheel by a mobile tyre fitter"
    trustItems={[
      { strong: '478', label: '★★★★★ Google reviews' },
      { strong: 'REACT', label: 'licensed & fully insured' },
      { strong: 'We come to you', label: 'fully equipped' },
    ]}
  />

  <section class="section section-white">
    <div class="container">
      <div class="service-split">
        <div class="service-split-image">
          <img
            src="/images/mobile-tyre-fitting.webp"
            alt="A newly fitted tyre with the Tyre Emergency service van visible in the background"
            width="1600"
            height="1200"
            loading="lazy"
          />
        </div>
        <div class="service-split-content">
          <span class="eyebrow">What you get</span>
          <h2>The full tyre-shop job, on your driveway</h2>
          <ul class="check-list">
            <li><strong>An exact, all-in price over the phone</strong> &mdash; brand, model, size and the total you&rsquo;ll pay, with no hidden costs added on the day.</li>
            <li><strong>Tyres fitted to manufacturer spec</strong> &mdash; not just slapped on. New valves, calibrated balancing and a torque-wrench finish on every wheel.</li>
            <li><strong>Old tyres taken away</strong> and recycled at a licensed facility &mdash; no mess left on your drive and no disposal charge.</li>
            <li><strong>An ETA you can plan around</strong> &mdash; we turn up when we say we will, which matters when you need the car for work or the school run later.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container container-narrow">
      <span class="eyebrow">When You Need This</span>
      <h2>Why people book us in</h2>
      <p>Mobile fitting just makes life easier. A few of the common reasons people get us out:</p>
      <div class="scenarios">
        <article class="scenario">
          <h3>MOT advisories to deal with</h3>
          <p>The MOT has flagged a worn or perished tyre. We&rsquo;ll match the size, brand and load rating and fit them on your driveway &mdash; receipt emailed across to file with the certificate.</p>
        </article>
        <article class="scenario">
          <h3>A full set before a long drive</h3>
          <p>Holiday, road trip, motorway-heavy week ahead. Pick a slot, leave the keys, get on with your day &mdash; we&rsquo;ll text when we&rsquo;re done.</p>
        </article>
        <article class="scenario">
          <h3>At work during the day</h3>
          <p>We come to the office car park while you&rsquo;re at your desk. Most people don&rsquo;t even need to step outside until we hand the keys back over.</p>
        </article>
        <article class="scenario">
          <h3>Seasonal swap onto winters</h3>
          <p>If you keep a separate set of winter or all-season tyres on their own wheels, we&rsquo;ll swap them on-site &mdash; balanced and torqued exactly as they should be.</p>
        </article>
      </div>
    </div>
  </section>

  
  <ReviewsSection />

  <section class="section section-white service-cta-section">
    <div class="container container-narrow text-center">
      <span class="eyebrow">Instant price</span>
      <h2>Want a price for your tyres?</h2>
      <p class="text-muted-dark">Pop your reg in and we&rsquo;ll send you straight to the booking site &mdash; live prices and slots, no waiting on a callback.</p>
      <div class="cta-row" style="justify-content: center;">
        <a class="btn btn-primary" href="/quote/?service=mobile-fitting">Get an instant price</a>
        <a class="btn btn-outline-dark btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Or call: {phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>


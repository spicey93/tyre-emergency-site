---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import { googleRating } from '../../data/reviews';
import { defaultPhone, defaultTelHref, defaultPhoneIntl } from '../../data/business';

const phone = defaultPhone;
const telHref = defaultTelHref;

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Mobile Tyre Repair',
  serviceType: 'Mobile Tyre Puncture Repair',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Tyre Emergency Ltd',
    telephone: defaultPhoneIntl,
    url: 'https://tyreemergencyltd.co.uk/',
  },
  areaServed: 'Nottinghamshire, East Midlands',
  description: 'On-site puncture repair carried out to British Standard AU159 across Nottinghamshire and the surrounding counties.',
  url: 'https://tyreemergencyltd.co.uk/services/mobile-tyre-repair/',
};
---

<BaseLayout
  title="Mobile Tyre Repair Nottinghamshire | BS AU159 Puncture Repair"
  description={`Mobile puncture repair carried out to British Standard AU159 within 8 miles of Bilsthorpe, Nottinghamshire. A proper repair saves the cost of a new tyre and gets years more out of yours. Call ${phone}.`}
  jsonLd={JSON.stringify(serviceJsonLd)}
>
  <HeroSection
    eyebrow="Repair Service · Nottinghamshire"
    title="Mobile Tyre Repair"
    subtitle="Proper puncture repair done right on your driveway. Save the cost of a new tyre when a repair will do."
    ctaPhone={phone}
    ctaCallLabel="Call for a price"
    secondaryCta={{ label: 'Get an instant price', href: '/quote/?service=puncture' }}
    bgImage="/images/emergency-tyre-replacement.webp"
    bgImageAlt="Tyre Emergency Ltd fitter replacing a flat tyre at the roadside"
    trustItems={[
      { strong: String(googleRating.reviewCount), label: '★★★★★ Google Reviews' },
      { strong: 'Same-day', label: 'Slots Most Days' },
      { strong: 'Saves', label: 'The Cost of a New Tyre' },
    ]}
  />

  <ReviewsSection variant="light" />

  <section class="section section-white">
    <div class="container">
      <div class="service-split">
        <div class="service-split-image">
          <img
            src="/images/puncture-repair.webp"
            alt="A Ford alloy wheel with a Bridgestone tyre ready to be inspected and repaired"
            width="1600"
            height="1200"
            loading="lazy"
          />
        </div>
        <div class="service-split-content">
          <span class="eyebrow">A few things worth knowing</span>
          <h2>How we handle puncture repairs</h2>
          <ul class="check-list">
            <li><strong>Within 8 miles of Bilsthorpe (NG22).</strong> Outside that radius the maths stops working for both of us, so we&rsquo;ll let you know rather than waste your time. The instant-price tool will check your postcode in a second.</li>
            <li><strong>Cheaper than fitting a new one.</strong> Where the puncture is safely repairable, a proper repair gets you years more out of the same tyre &mdash; for a fraction of what a new tyre would cost.</li>
            <li><strong>Done to BS AU159</strong> &mdash; tyre off the rim, full inside inspection and a combined plug-and-patch from the inside, not a string-and-glue job stuck in from the outside.</li>
            <li><strong>Re-balanced after the repair</strong> on the mobile balancer, pressures set to the manufacturer&rsquo;s figure.</li>
            <li><strong>Honest call on whether it&rsquo;s worth repairing</strong> &mdash; if the tyre&rsquo;s near the end of its life anyway, we&rsquo;ll tell you straight rather than charge you for a repair that&rsquo;s only going to last weeks.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container container-narrow">
      <span class="eyebrow">When You Need This</span>
      <h2>Typical repair jobs</h2>
      <div class="scenarios">
        <article class="scenario">
          <h3>Screw or nail in the tread</h3>
          <p>You&rsquo;ve spotted the head of a screw in the tyre or pulled one out and it&rsquo;s now going down. If it&rsquo;s in the central tread area, this is exactly the sort of puncture we can repair properly and give you years more out of the tyre.</p>
        </article>
        <article class="scenario">
          <h3>Slow puncture you keep topping up</h3>
          <p>You&rsquo;ve been pumping it up every few days and it&rsquo;s starting to get annoying. We&rsquo;ll get the tyre off, find the leak (often a tiny shard of glass) and tell you whether to repair it or replace it.</p>
        </article>
        <article class="scenario">
          <h3>Plenty of tread left, don&rsquo;t want to bin it</h3>
          <p>The tyre is fairly new, the tread is good, and you don&rsquo;t want to spend money on a new one if a proper repair will do. If it&rsquo;s safely repairable, that&rsquo;s the call we&rsquo;ll make.</p>
        </article>
        <article class="scenario">
          <h3>Pre-trip check before a long drive</h3>
          <p>Tyre&rsquo;s losing air slowly and you&rsquo;ve got a long journey coming up. We&rsquo;ll get it sorted on the driveway so you can leave without it nagging at the back of your mind.</p>
        </article>
      </div>
    </div>
  </section>


  <section class="section section-white service-cta-section">
    <div class="container container-narrow text-center">
      <span class="eyebrow">Instant price</span>
      <h2>Got a puncture? Get a price now.</h2>
      <p class="text-muted-dark">Pop your postcode in and we&rsquo;ll work out whether you&rsquo;re in our zone, show you the all-in price and let you book a slot.</p>
      <div class="cta-row" style="justify-content: center;">
        <a class="btn btn-primary" href="/quote/?service=puncture">Get an instant price</a>
        <a class="btn btn-outline-dark btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Or call: {phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

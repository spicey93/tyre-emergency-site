---
import BaseLayout from '../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
---

<BaseLayout
  title="Page Not Found | Tyre Emergency Ltd"
  description="The page you're looking for doesn't exist. Call Tyre Emergency Ltd on 01623 325 123 for 24/7 mobile tyre fitting across Nottinghamshire."
>
  <section class="notfound-hero">
    <div class="container">
      <div class="notfound-inner">
        <span class="notfound-code" aria-hidden="true">404</span>
        <h1>Page not found.</h1>
        <p>The page you&rsquo;re looking for doesn&rsquo;t exist or has moved. If you need a tyre sorted, the fastest route is always a phone call.</p>
        <div class="cta-row">
          <a class="btn btn-primary btn-call" href={telHref}>
            <span aria-hidden="true">&#9742;</span> Call Now: {phone}
          </a>
          <a class="btn btn-outline" href="/">Back to Home</a>
        </div>
        <nav class="notfound-nav" aria-label="Helpful links">
          <p class="notfound-nav-label">Or go straight to:</p>
          <ul>
            <li><a href="/services/">All Services</a></li>
            <li><a href="/areas/">Areas Covered</a></li>
            <li><a href="/about/">About</a></li>
            <li><a href="/contact/">Contact</a></li>
          </ul>
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound-hero {
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    background-color: var(--color-bg-white);
    color: var(--color-text-dark);
    padding: 4rem 0;
  }

  .notfound-inner {
    max-width: 560px;
  }

  .notfound-code {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(5rem, 16vw, 10rem);
    line-height: 1;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
    letter-spacing: -0.03em;
  }

  .notfound-inner h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .notfound-inner p {
    color: var(--color-text-muted-dark);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .notfound-nav {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .notfound-nav-label {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.75rem !important;
  }

  .notfound-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .notfound-nav a {
    color: var(--color-text);
    font-weight: 500;
  }

  .notfound-nav a:hover {
    color: var(--color-accent);
  }
</style>

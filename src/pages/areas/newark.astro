---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Newark';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 A1 & A46 Tyre Service`}
  description={`24/7 mobile tyre fitting and emergency callouts in ${town}-on-Trent and along the A1 corridor. 20-minute average ETA from Bilsthorpe. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        24/7 mobile tyre fitting across Newark-on-Trent and the surrounding villages. 20-minute average ETA from our Bilsthorpe base.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers call us first</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>Based on your doorstep</h3>
          <p>Bilsthorpe is ten minutes from Newark, which means a 20-minute average ETA that we can genuinely stand behind. Fast response isn&rsquo;t a promise we make &mdash; it&rsquo;s just the geography.</p>
        </li>
        <li class="area-point">
          <h3>Fast A1 response</h3>
          <p>The A1 through Newark produces a steady flow of tyre emergencies. Tyre Emergency is REACT licensed and experienced in working safely on fast A-roads when a roadside callout is needed.</p>
        </li>
        <li class="area-point">
          <h3>Trusted by Newark businesses</h3>
          <p>Several local trade businesses and fleet operators use us as their first call. Same-day response, fixed pricing, and no hassle.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Same fast service across the {town} catchment</h2>
      <p class="text-muted">If you&rsquo;re heading north or south on the A1, or out towards Lincoln on the A46, we&rsquo;ve got the area covered. Click any nearby town for more:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/southwell/">Southwell</a>
        <a class="tag" href="/areas/lincoln/">Lincoln</a>
        <a class="tag" href="/areas/grantham/">Grantham</a>
        <a class="tag" href="/areas/mansfield/">Mansfield</a>
        <a class="tag" href="/areas/tuxford/">Tuxford</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Stuck in {town}?</h2>
      <p class="text-muted-dark">Call us now and you&rsquo;ll have a real ETA and a fixed price within minutes.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

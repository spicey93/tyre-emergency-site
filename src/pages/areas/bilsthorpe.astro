---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import { areaPhones, telHrefFor } from '../../data/business';

const phone = areaPhones.bilsthorpe;
const telHref = telHrefFor(phone);
const town = 'Bilsthorpe';
---

<BaseLayout
  phone={phone}
  title={`Free Mobile Tyre Fitting in ${town} | Tyre Emergency Ltd`}
  description={`Mobile tyre fitting in ${town} with no travel fee on planned jobs — we're based right here in the village (NG22). Emergency replacement, puncture repair, caravan tyres, locking wheel nut removal. Call ${phone}.`}
>
  <HeroSection
    eyebrow={town}
    title={`Free Mobile Tyre Fitting in ${town}`}
    subtitle="We&rsquo;re based in the village &mdash; no travel fee for planned mobile tyre fitting on your driveway."
    ctaPhone={phone}
    ctaCallLabel="Call us"
    secondaryCta={{ label: 'Get an instant price', href: '/quote/' }}
    bgImage="/images/mobile-tyres.webp"
    bgImageAlt="A newly fitted Bridgestone tyre with the Tyre Emergency Ltd service van in the background"
  />


  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow">What we do in {town}</span>
      <h2>The full mobile tyre service, on your driveway</h2>
      <p>Because we&rsquo;re based in the village, we can usually be with you in minutes &mdash; and there&rsquo;s no travel fee to factor in on a planned job. Urgent and out-of-hours callouts are still chargeable, but the price is agreed on the phone before we set off.</p>
      <ul class="area-points">
        <li class="area-point">
          <h3>Emergency tyre replacement</h3>
          <p>Stranded on the driveway or on a country lane near the village? We&rsquo;re ready to go at a moment&rsquo;s notice with the right tyre and the kit to fit it on the spot.</p>
        </li>
        <li class="area-point">
          <h3>Mobile tyre fitting at home or work</h3>
          <p>Everything a tyre shop does &mdash; fitted, balanced and torqued correctly &mdash; without you driving anywhere or sitting in a waiting room.</p>
        </li>
        <li class="area-point">
          <h3>Puncture repairs</h3>
          <p>If your tyre still has plenty of life in it, a proper BS AU159 repair saves you fitting a new one.</p>
        </li>
        <li class="area-point">
          <h3>Caravans, motorhomes and trailers</h3>
          <p>No towing the &lsquo;van anywhere &mdash; we come to you and handle motor movers, Tyron bands and the rest with care.</p>
        </li>
        <li class="area-point">
          <h3>Locking wheel nut removal</h3>
          <p>Damaged locker stopping you getting other work done? Lost the key, stripped the pattern, seized on the stud &mdash; we get them off and a standard nut back on.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-light">
    <div class="container container-narrow">
      <span class="eyebrow">Why drivers in {town} choose us</span>
      <h2>The local mobile tyre service &mdash; literally on your doorstep</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>No travel fee on planned jobs</h3>
          <p>{town} is where we&rsquo;re based, so there&rsquo;s no travel charge to factor in on a planned mobile fitting &mdash; just the cost of the tyre and the work. Urgent and out-of-hours callouts are charged separately, but agreed up front and never sprung on you on arrival.</p>
        </li>
        <li class="area-point">
          <h3>Genuinely fast in the village</h3>
          <p>Most of our {town} jobs are sorted within the hour. We give you an honest ETA on the phone before we set off &mdash; not a best-case figure to get you off the call.</p>
        </li>
        <li class="area-point">
          <h3>The same experienced fitter every time</h3>
          <p>It&rsquo;s a sole-operator business. The person who answers the phone is the one who turns up at your door &mdash; the same neighbour every time.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby areas also covered</span>
      <h2>Just outside {town}? We&rsquo;ve still got you</h2>
      <p>Plenty of our regulars are in the surrounding villages and towns. Tap any of these for more, or just give us a call.</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/edwinstowe/">Edwinstowe</a>
        <a class="tag" href="/areas/ollerton/">Ollerton</a>
        <a class="tag" href="/areas/farnsfield/">Farnsfield</a>
        <a class="tag" href="/areas/rainworth/">Rainworth</a>
        <a class="tag" href="/areas/mansfield/">Mansfield</a>
        <a class="tag" href="/areas/southwell/">Southwell</a>
        <a class="tag" href="/areas/newark/">Newark</a>
        <a class="tag" href="/areas/worksop/">Worksop</a>
      </div>
    </div>
  </section>

  <ReviewsSection variant="light" />

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Tyre trouble in {town}?</h2>
      <p class="text-muted-dark">Pick up the phone and you&rsquo;ll have an exact, all-in price and a realistic ETA within minutes.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

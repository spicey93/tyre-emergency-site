---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Retford';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 A1 & A638 Tyre Service`}
  description={`24/7 mobile tyre fitting throughout ${town} and along the A1 corridor. 35-minute average ETA from Bilsthorpe. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        24/7 mobile tyre fitting across Retford and the surrounding Bassetlaw area. 35-minute average ETA from our Bilsthorpe base.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers stick with us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>Local Bassetlaw response</h3>
          <p>Bilsthorpe to Retford is a 30-minute run on a clear day. We&rsquo;re a faster bet than fitters coming up from Nottingham or down from Doncaster for most callouts.</p>
        </li>
        <li class="area-point">
          <h3>Experienced A1 emergency response</h3>
          <p>The Retford stretch of the A1 produces regular tyre emergencies. Tyre Emergency is REACT licensed and experienced in working safely on fast A-roads when a roadside callout is needed.</p>
        </li>
        <li class="area-point">
          <h3>Rural Bassetlaw covered</h3>
          <p>Village postcodes and rural B-roads around Retford are no problem. We come to wherever the vehicle is and get the job done on-site.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} catchment</h2>
      <p class="text-muted">If you&rsquo;re anywhere along the A1 north of Newark or out into rural Bassetlaw:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/blyth/">Blyth</a>
        <a class="tag" href="/areas/worksop/">Worksop</a>
        <a class="tag" href="/areas/tuxford/">Tuxford</a>
        <a class="tag" href="/areas/doncaster/">Doncaster</a>
        <a class="tag" href="/areas/lincoln/">Lincoln</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Stuck in {town} or on the A1?</h2>
      <p class="text-muted-dark">Call us and you&rsquo;ll have a real ETA confirmed in no time.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

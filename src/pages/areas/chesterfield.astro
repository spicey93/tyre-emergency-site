---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Chesterfield';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 M1 & A61 Tyre Service`}
  description={`24/7 mobile tyre fitting throughout ${town} and the M1 J29-J30 corridor. 35-minute average ETA from our Bilsthorpe base. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        Chesterfield sits at the western edge of Dean&rsquo;s regular coverage area, reached via the A617 from Mansfield and the A61. Average ETA from Bilsthorpe into central Chesterfield is 35 minutes. He covers the town centre and surrounding areas including Brimington, Old Whittington, Walton and Brampton, as well as the trade and business estates around Markham Vale. Emergency callouts, home fitting, workplace fitting &mdash; the job gets done wherever the vehicle is.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers call us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>REACT licensed for motorway and A-road work</h3>
          <p>The M1 between J29 and J30 produces regular tyre emergencies. Dean is REACT licensed and qualified to work safely on motorways and fast carriageways.</p>
        </li>
        <li class="area-point">
          <h3>Competitive even at the edge of the patch</h3>
          <p>Chesterfield is Dean&rsquo;s furthest west, but the A617 link keeps response times honest. The pricing is the same fixed-price model as every other job &mdash; no distance loading.</p>
        </li>
        <li class="area-point">
          <h3>Business and trade customers welcome</h3>
          <p>Several operators around Markham Vale use Dean for same-day van fitting. Fixed pricing, prompt response, no surprise add-ons.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} region</h2>
      <p class="text-muted">If you&rsquo;re anywhere along the M1 corridor or the A617, we&rsquo;ve got you covered:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/mansfield/">Mansfield</a>
        <a class="tag" href="/areas/worksop/">Worksop</a>
        <a class="tag" href="/areas/blyth/">Blyth</a>
        <a class="tag" href="/areas/doncaster/">Doncaster</a>
        <a class="tag" href="/areas/nottingham/">Nottingham</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Stuck in {town}?</h2>
      <p class="text-muted-dark">We&rsquo;re probably less far away than you think. Phone the line for a real-time ETA.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

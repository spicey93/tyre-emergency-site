---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Chesterfield';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 M1 & A61 Tyre Service`}
  description={`24/7 mobile tyre fitting throughout ${town} and the M1 J29-J30 corridor. 35-minute average ETA from our Bilsthorpe base. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        Chesterfield is the western edge of our regular run, served via the A617 from Mansfield and the A61 north-south. Average ETA from Bilsthorpe into central S40 or S41 is 35 minutes, and we&rsquo;re a frequent caller on the M1 between J29 and J30 where the carriageway curves through Hardwick and the Whittington bypass. We cover the centre of Chesterfield, Brimington, Old Whittington, Walton, Brampton and the trade estates around Markham Vale, plus the residential streets either side of the famous crooked spire.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers call us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>M1 J29 / J30 specialists</h3>
          <p>The M1 between Heath and Barlborough generates a steady flow of motorway callouts. We work this stretch in coordination with Highways and recovery operators most weeks.</p>
        </li>
        <li class="area-point">
          <h3>Fast across into Derbyshire</h3>
          <p>Chesterfield sits in our extended catchment, but our Bilsthorpe location and the A617 link make us as quick as most local fitters &mdash; and almost always cheaper at weekends.</p>
        </li>
        <li class="area-point">
          <h3>Markham Vale fleet support</h3>
          <p>We support several distribution operators around Markham Vale with same-day van and trailer fitting. Account billing, fixed pricing, no surprise add-ons.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} region</h2>
      <p class="text-muted">If you&rsquo;re anywhere along the M1 corridor or the A617, we&rsquo;ve got you covered:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/mansfield/">Mansfield</a>
        <a class="tag" href="/areas/worksop/">Worksop</a>
        <a class="tag" href="/areas/blyth/">Blyth</a>
        <a class="tag" href="/areas/doncaster/">Doncaster</a>
        <a class="tag" href="/areas/nottingham/">Nottingham</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Stuck in {town}?</h2>
      <p class="text-muted-dark">We&rsquo;re probably less far away than you think. Phone the line for a real-time ETA.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

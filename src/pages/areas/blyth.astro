---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Blyth';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 A1 & A634 Tyre Service`}
  description={`24/7 mobile tyre fitting in ${town} (Nottinghamshire) and along the A1 corridor. 35-minute average ETA from Bilsthorpe. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        Blyth sits at the northern edge of Dean&rsquo;s regular Nottinghamshire coverage, at the A1/A614 junction. Average ETA from Bilsthorpe is 35 minutes. He covers Blyth, Hodsock, Bawtry, Ranskill, Mattersey, Torworth and Barnby Moor &mdash; emergency callouts and pre-booked fitting handled equally well. The tyre is sourced before Dean sets off and the job is finished on-site, wherever the vehicle has stopped.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers call us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>REACT licensed for A1 emergencies</h3>
          <p>The A1 through Blyth generates regular tyre emergencies. Dean is REACT licensed and trained to work safely on fast carriageways when a blowout has happened at speed.</p>
        </li>
        <li class="area-point">
          <h3>Cars, vans and caravans all covered</h3>
          <p>Whatever you&rsquo;re driving, Dean sources the correct tyre before setting off. Cars, SUVs, light commercial vans and caravans all handled on-site.</p>
        </li>
        <li class="area-point">
          <h3>Genuinely 24/7</h3>
          <p>Dean answers the phone himself through the small hours. If something has gone wrong on the A1 late at night, you&rsquo;re not getting a voicemail or a callback service.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} catchment</h2>
      <p class="text-muted">A short run in any direction:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/worksop/">Worksop</a>
        <a class="tag" href="/areas/retford/">Retford</a>
        <a class="tag" href="/areas/doncaster/">Doncaster</a>
        <a class="tag" href="/areas/tuxford/">Tuxford</a>
        <a class="tag" href="/areas/chesterfield/">Chesterfield</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Stuck in {town} or on the A1?</h2>
      <p class="text-muted-dark">Phone the line and we&rsquo;ll dispatch the closest fitting van &mdash; usually one already on the A1 corridor.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Lincoln';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 A46 & A57 Tyre Service`}
  description={`24/7 mobile tyre fitting throughout ${town} and along the A46 and A57. 50-minute average ETA from our Bilsthorpe base. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        24/7 mobile tyre fitting across Lincoln and the surrounding LN postcodes. 50-minute average ETA from our Bilsthorpe base.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers call us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>Full service, wherever you are</h3>
          <p>Emergency replacement, planned fitting, puncture repair, locking nut removal and TPMS &mdash; we handle all of it on-site, at whatever location works for you.</p>
        </li>
        <li class="area-point">
          <h3>REACT licensed for A-road emergencies</h3>
          <p>The A46 and A57 in and out of Lincoln see regular roadside emergencies. Tyre Emergency is REACT licensed and qualified to work safely on fast A-roads when a roadside callout is needed.</p>
        </li>
        <li class="area-point">
          <h3>Fixed pricing, no postcode loading</h3>
          <p>The same all-in quote model whether you&rsquo;re in central Lincoln or a surrounding village. The price you&rsquo;re told before we set off is the price you pay.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} region</h2>
      <p class="text-muted">From Lincoln we serve a wide rural catchment. Some popular nearby areas:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/newark/">Newark</a>
        <a class="tag" href="/areas/grantham/">Grantham</a>
        <a class="tag" href="/areas/retford/">Retford</a>
        <a class="tag" href="/areas/tuxford/">Tuxford</a>
        <a class="tag" href="/areas/southwell/">Southwell</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Need a fitter in {town}?</h2>
      <p class="text-muted-dark">Call us and you&rsquo;ll have a fixed price and an ETA in no time.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Worksop';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 A57 & A1 Tyre Service`}
  description={`24/7 mobile tyre fitting and emergency replacement throughout ${town} and along the A57 and A1. 30-minute average ETA from Bilsthorpe. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        Dean covers Worksop and the surrounding S80 postcode with a 30-minute average ETA from Bilsthorpe. He handles emergency callouts and pre-booked fitting across Worksop, Carlton-in-Lindrick, Manton, Kilton, Shireoaks and Rhodesia, as well as the trade and industrial areas around Manton Wood and Sandy Lane. Whatever the job &mdash; blowout, flat, MOT tyre, locking nut, TPMS &mdash; he arrives with the right tyre already sourced and the kit to finish it on-site.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers stick with us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>REACT licensed roadside work</h3>
          <p>Dean is REACT licensed, which means he&rsquo;s qualified to work safely on fast A-roads and motorways &mdash; important when a tyre goes on the A1 or A57 at speed.</p>
        </li>
        <li class="area-point">
          <h3>Cars and vans covered</h3>
          <p>Cars, SUVs, light vans and commercial vehicles up to 3.5 tonnes &mdash; the right tyres are sourced before the job and arrive with Dean ready to fit.</p>
        </li>
        <li class="area-point">
          <h3>24/7, no exceptions</h3>
          <p>Dean answers the phone through the small hours and at weekends. If a flat tyre is stopping you getting somewhere, the time of day doesn&rsquo;t change that.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} catchment</h2>
      <p class="text-muted">A short hop in any direction and we&rsquo;ve got you covered:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/retford/">Retford</a>
        <a class="tag" href="/areas/blyth/">Blyth</a>
        <a class="tag" href="/areas/mansfield/">Mansfield</a>
        <a class="tag" href="/areas/doncaster/">Doncaster</a>
        <a class="tag" href="/areas/chesterfield/">Chesterfield</a>
        <a class="tag" href="/areas/tuxford/">Tuxford</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Tyre trouble in {town}?</h2>
      <p class="text-muted-dark">Call Dean and you&rsquo;ll get a real ETA and a fixed quoted price &mdash; all on the first call.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

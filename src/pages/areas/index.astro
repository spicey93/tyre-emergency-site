---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;

const areas = [
  { name: 'Mansfield', slug: 'mansfield', eta: '25 min', blurb: 'Full mobile service across Mansfield and the surrounding NG18/NG19 villages — emergency callouts, planned fitting, repairs, caravans, the lot.' },
  { name: 'Nottingham', slug: 'nottingham', eta: '35 min', blurb: 'Mobile fitting across the whole NG postcode. We come to homes, workplaces and roadside callouts right across the city and suburbs.' },
  { name: 'Newark', slug: 'newark', eta: '20 min', blurb: 'One of our closest postcodes. We cover Newark-on-Trent and the surrounding villages for everything from a planned set of four to a 2am roadside emergency.' },
  { name: 'Worksop', slug: 'worksop', eta: '30 min', blurb: 'Full mobile tyre service across S80 — at home, at work or on the roadside. Cars, vans and caravans all sorted on-site.' },
  { name: 'Chesterfield', slug: 'chesterfield', eta: '35 min', blurb: 'We come to you across Chesterfield and the surrounding area for emergency callouts, planned fitting and everything in between.' },
  { name: 'Doncaster', slug: 'doncaster', eta: '45 min', blurb: 'Full mobile tyre service across the DN postcode — homes, workplaces and roadside emergencies, day or night.' },
  { name: 'Lincoln', slug: 'lincoln', eta: '50 min', blurb: 'Mobile fitting across Lincoln and the surrounding LN postcodes. Whatever the job, we bring it all with us.' },
  { name: 'Retford', slug: 'retford', eta: '35 min', blurb: 'Across Retford and the wider Bassetlaw area. Fitting at home, on the roadside or at the workplace, day or night.' },
  { name: 'Grantham', slug: 'grantham', eta: '50 min', blurb: 'Full mobile tyre service across Grantham and the surrounding villages. Particularly handy for caravans and motorhomes you don\'t want to tow anywhere.' },
  { name: 'Southwell', slug: 'southwell', eta: '20 min', blurb: 'Practically on our doorstep. The full mobile service for cars, vans, caravans and trailers without you moving an inch.' },
  { name: 'Tuxford', slug: 'tuxford', eta: '25 min', blurb: 'Mobile tyre fitting across Tuxford and the surrounding villages — homes, workplaces, roadside callouts, all of it.' },
  { name: 'Blyth', slug: 'blyth', eta: '35 min', blurb: 'Full mobile tyre service across Blyth and the surrounding north Notts villages.' },
];
---

<BaseLayout
  title="Areas Covered | Mobile Tyre Fitting Nottinghamshire & East Midlands"
  description="Twelve towns and a wide rural catchment across Nottinghamshire and the East Midlands. Mansfield, Nottingham, Newark, Worksop, Chesterfield, Doncaster, Lincoln, Retford, Grantham, Southwell, Tuxford and Blyth."
>
  <HeroSection
    eyebrow="Coverage · Nottinghamshire & East Midlands"
    title="Twelve towns. One county."
    subtitle="Based in Bilsthorpe, smack in the middle of Notts. Whole county on our doorstep, plus a fair chunk of Lincs, South Yorks and Derbyshire."
    ctaPhone={phone}
    ctaCallLabel="Call us"
    bgImage="/images/tyre-emergency-ltd.webp"
    bgImageAlt="Tyre Emergency Ltd service van ready to head out across the East Midlands"
  />
  <section class="section section-light">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">Pick your area</span>
        <h2>Where we cover</h2>
        <p class="section-lede-dark">Typical ETAs from our Bilsthorpe base &mdash; honest figures, not best-case ones. We&rsquo;ll always confirm a realistic live ETA when you ring.</p>
      </div>

      <div class="grid grid-3 areas-grid">
        {areas.map((a) => (
          <a class="area-tile" href={`/areas/${a.slug}/`}>
            <div class="area-tile-head">
              <h3>{a.name}</h3>
              <span class="area-eta">~{a.eta}</span>
            </div>
            <p>{a.blurb}</p>
            <span class="area-tile-link">View {a.name} <span aria-hidden="true">&rarr;</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  
  <ReviewsSection />

  <section class="section section-light">
    <div class="container container-narrow text-center">
      <span class="eyebrow">Not on the list?</span>
      <h2>Give us a call anyway.</h2>
      <p class="text-muted">If you&rsquo;re anywhere near one of these towns, the answer&rsquo;s almost certainly yes. And if we genuinely can&rsquo;t reach you fast enough, we&rsquo;ll point you to someone reliable who can &mdash; we&rsquo;d rather you get sorted than sat in limbo.</p>
      <div class="cta-row" style="justify-content: center; margin-top: 1rem;">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call {phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-lede-dark {
    max-width: 60ch;
    margin: 0 auto 3rem;
    font-size: 1.1rem;
    color: var(--color-text-muted-dark);
  }

  .areas-grid {
    margin-top: 1rem;
  }

  .area-tile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.6rem 1.4rem;
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    color: var(--color-text-dark);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    height: 100%;
  }

  .area-tile:hover {
    transform: translateY(-3px);
    border-color: var(--color-text-dark);
    color: var(--color-text-dark);
    box-shadow: 0 18px 36px -22px rgba(0, 0, 0, 0.35);
  }

  .area-tile-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .area-tile-head h3 {
    font-size: 1.4rem;
    margin: 0;
    color: var(--color-text-dark);
  }

  .area-eta {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.55rem;
    background-color: rgba(0, 0, 0, 0.06);
    color: var(--color-text-dark);
    border-radius: 999px;
    flex-shrink: 0;
  }

  .area-tile p {
    color: var(--color-text-muted-dark);
    font-size: 0.95rem;
    margin: 0;
    flex-grow: 1;
  }

  .area-tile-link {
    color: var(--color-text-dark);
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  .area-tile:hover .area-tile-link {
    color: var(--color-accent);
  }
</style>

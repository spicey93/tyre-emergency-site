---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';

const phone = '0330 133 9311';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Nottingham';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town}`}
  description={`Mobile tyre fitting, emergency replacement, puncture repair, caravan tyres, locking wheel nut removal in ${town}. We come to you. Call 0330 133 9311.`}
>
  <HeroSection
    eyebrow={town}
    title={`Mobile Tyre Fitting in ${town}`}
    subtitle="Mobile tyre fitting in Nottingham — driveways, work car parks, the roadside. We come to you."
    ctaPhone={phone}
    ctaCallLabel="Call us"
    secondaryCta={{ label: 'Get an instant price', href: '/quote/' }}
    bgImage="/images/mobile-tyres.webp"
    bgImageAlt="A newly fitted Bridgestone tyre with the Tyre Emergency Ltd service van in the background"
  />


  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow">What we do in {town}</span>
      <h2>The full mobile tyre service, on your driveway or wherever you&rsquo;ve stopped</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>Emergency tyre replacement</h3>
          <p>Stranded with a flat at the worst possible time? We&rsquo;re ready to go at a moment&rsquo;s notice with the right tyre and the kit to fit it on the spot.</p>
        </li>
        <li class="area-point">
          <h3>Mobile tyre fitting at home or work</h3>
          <p>Everything a tyre shop does &mdash; fitted, balanced and torqued correctly &mdash; without you driving anywhere or sitting in a waiting room.</p>
        </li>
        <li class="area-point">
          <h3>Caravans, motorhomes and trailers</h3>
          <p>No towing the &lsquo;van anywhere &mdash; we come to you and handle motor movers, Tyron bands and the rest with care.</p>
        </li>
        <li class="area-point">
          <h3>Locking wheel nut removal</h3>
          <p>Damaged locker stopping you getting other work done? Lost the key, stripped the pattern, seized on the stud &mdash; we get them off and a standard nut back on.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-light">
    <div class="container container-narrow">
      <span class="eyebrow">Why drivers in {town} choose us</span>
      <h2>Built for speed, convenience and turning up on time</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>An exact price, an honest ETA</h3>
          <p>We give you the all-in price and a realistic ETA on the phone before we set off &mdash; no hidden costs and no best-case promises that don&rsquo;t happen.</p>
        </li>
        <li class="area-point">
          <h3>We arrive on time</h3>
          <p>Important when you need the car for work or the school run. The cheaper mobile fitters can be unreliable and let people down &mdash; that&rsquo;s the gap we&rsquo;re built to fill.</p>
        </li>
        <li class="area-point">
          <h3>Phone answered by a real person, day or night</h3>
          <p>You&rsquo;re not getting a voicemail or a callback queue. Pick up the phone and you&rsquo;re straight through to the person who&rsquo;ll be turning up at your door.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby areas also covered</span>
      <h2>Just outside {town}? We&rsquo;ve still got you</h2>
      <p>Plenty of our regulars are in the surrounding villages and towns. Tap any of these for more, or just give us a call.</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/southwell/">Southwell</a>
        <a class="tag" href="/areas/mansfield/">Mansfield</a>
        <a class="tag" href="/areas/newark/">Newark</a>
        <a class="tag" href="/areas/grantham/">Grantham</a>
        <a class="tag" href="/areas/chesterfield/">Chesterfield</a>
      </div>
    </div>
  </section>

  <ReviewsSection variant="light" />

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Tyre trouble in {town}?</h2>
      <p class="text-muted-dark">Pick up the phone and you&rsquo;ll have an exact price and a realistic ETA within minutes.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Nottingham';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 Emergency Tyre Service`}
  description={`24/7 mobile tyre fitting and emergency replacement throughout ${town} city centre and suburbs. 35-minute average ETA, fixed pricing, REACT licensed. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        Nottingham is one of Dean&rsquo;s busiest areas. From Bilsthorpe the average ETA into the city is 35 minutes, covering the city centre, West Bridgford, Mapperley, Carlton, Beeston, Bulwell and everywhere in between. Whether you&rsquo;ve had a blowout, picked up a nail, need an MOT advisory tyre sorted at home, or want four new tyres fitted at the office while you&rsquo;re in a meeting &mdash; Dean comes to wherever the car is and gets the job done on-site.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers stick with us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>35-minute average into the city</h3>
          <p>The A60 and A614 from Bilsthorpe put Dean well within range for a genuinely fast response across the whole NG postcode area &mdash; city centre to suburbs.</p>
        </li>
        <li class="area-point">
          <h3>Business and fleet-friendly</h3>
          <p>Dean works with several Nottingham-based businesses and trade operators. Same-day response, fixed pricing, and no setup hassle when a vehicle goes down.</p>
        </li>
        <li class="area-point">
          <h3>Same price, any time</h3>
          <p>The quote you get at 9am is the same structure as the one at 11pm. No surge pricing, no weekend loading, no hidden extras on arrival.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Beyond the {town} ring road</h2>
      <p class="text-muted">We cover the whole NG postcode area and well beyond. Common nearby areas:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/southwell/">Southwell</a>
        <a class="tag" href="/areas/mansfield/">Mansfield</a>
        <a class="tag" href="/areas/newark/">Newark</a>
        <a class="tag" href="/areas/grantham/">Grantham</a>
        <a class="tag" href="/areas/chesterfield/">Chesterfield</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Need a fitter in {town} right now?</h2>
      <p class="text-muted-dark">Call the number and Dean will give you a real ETA and a fixed price before he sets off.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

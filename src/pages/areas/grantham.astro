---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Grantham';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 A1 & A52 Tyre Service`}
  description={`24/7 mobile tyre fitting throughout ${town} and along the A1 south corridor. 50-minute average ETA from Bilsthorpe. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        Grantham sits at the southern edge of Dean&rsquo;s regular coverage area, reached via the A1 from Newark or the A52 from Nottingham. Average ETA into central Grantham is 50 minutes. He covers Grantham and the surrounding villages including Barrowby, Great Gonerby, Harlaxton and Manthorpe. Whether the tyre has let go on the A1, on a residential street or in a car park &mdash; Dean arrives with the right tyre already sourced and the kit to finish the job on-site.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers call us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>REACT licensed for A1 emergencies</h3>
          <p>The A1 through Grantham produces regular tyre callouts. Dean is REACT licensed and experienced in working safely on fast carriageways when a blowout has happened at speed.</p>
        </li>
        <li class="area-point">
          <h3>Fixed pricing, no postcode loading</h3>
          <p>The same all-in quote model whether you&rsquo;re in central Grantham or a surrounding village. The price you hear on the phone is the price you pay &mdash; no extras on arrival.</p>
        </li>
        <li class="area-point">
          <h3>Caravans and motorhomes covered</h3>
          <p>The A52 and A1 see regular caravan and motorhome traffic. Dean is experienced with leisure vehicle tyres &mdash; correct load ratings, careful handling, sourced to order.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} region</h2>
      <p class="text-muted">If you&rsquo;re anywhere along the A1 south of Newark or out east on the A52:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/newark/">Newark</a>
        <a class="tag" href="/areas/lincoln/">Lincoln</a>
        <a class="tag" href="/areas/southwell/">Southwell</a>
        <a class="tag" href="/areas/nottingham/">Nottingham</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Tyre trouble in {town}?</h2>
      <p class="text-muted-dark">Phone the line for an honest ETA and a fixed quote on the spot.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

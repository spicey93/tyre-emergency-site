---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import ReviewsSection from '../../components/ReviewsSection.astro';
import { areaPhones, telHrefFor } from '../../data/business';

const phone = areaPhones.edwinstowe;
const telHref = telHrefFor(phone);
const town = 'Edwinstowe';
---

<BaseLayout
  phone={phone}
  title={`Free Mobile Tyre Fitting in ${town} | Tyre Emergency Ltd`}
  description={`Mobile tyre fitting in ${town} with no travel fee on planned jobs — we're three miles down the road in Bilsthorpe. We also come out to Center Parcs Sherwood Forest. Call ${phone}.`}
>
  <HeroSection
    eyebrow={town}
    title={`Free Mobile Tyre Fitting in ${town}`}
    subtitle="We&rsquo;re based three miles south in Bilsthorpe &mdash; no travel fee for planned mobile fitting in the village."
    ctaPhone={phone}
    ctaCallLabel="Call us"
    secondaryCta={{ label: 'Get an instant price', href: '/quote/' }}
    bgImage="/images/mobile-tyres.webp"
    bgImageAlt="A newly fitted Bridgestone tyre with the Tyre Emergency Ltd service van in the background"
  />

  <ReviewsSection variant="light" />

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow">What we do in {town}</span>
      <h2>The full mobile tyre service &mdash; on your driveway or on holiday</h2>
      <p>Because we&rsquo;re only a few minutes down the road, we can usually be with you in {town} quickly &mdash; and there&rsquo;s no travel fee to factor in on a planned job. Urgent and out-of-hours callouts are still chargeable, but the price is agreed on the phone before we set off.</p>
      <ul class="area-points">
        <li class="area-point">
          <h3>Emergency tyre replacement</h3>
          <p>Stranded with a flat on the A6075 or in a {town} car park? We&rsquo;re ready to go at a moment&rsquo;s notice with the right tyre and the kit to fit it on the spot.</p>
        </li>
        <li class="area-point">
          <h3>Mobile tyre fitting at home or work</h3>
          <p>Everything a tyre shop does &mdash; fitted, balanced and torqued correctly &mdash; without you driving anywhere or sitting in a waiting room.</p>
        </li>
        <li class="area-point">
          <h3>Puncture repairs</h3>
          <p>If your tyre still has plenty of life in it, a proper BS AU159 repair saves you fitting a new one.</p>
        </li>
        <li class="area-point">
          <h3>Caravans, motorhomes and trailers</h3>
          <p>No towing the &lsquo;van anywhere &mdash; we come to you and handle motor movers, Tyron bands and the rest with care.</p>
        </li>
        <li class="area-point">
          <h3>Locking wheel nut removal</h3>
          <p>Damaged locker stopping you getting other work done? Lost the key, stripped the pattern, seized on the stud &mdash; we get them off and a standard nut back on.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-light">
    <div class="container container-narrow">
      <span class="eyebrow">Why drivers in {town} choose us</span>
      <h2>Genuinely local &mdash; including at Center Parcs</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>On site at Center Parcs Sherwood Forest</h3>
          <p>Plenty of our {town} jobs are for holidaymakers at Center Parcs who&rsquo;ve found a flat on the morning they were due to drive home. Rather than write off the day, we come on site, fit a tyre at your lodge and you carry on with the holiday. Pop your reg on the phone and we&rsquo;ll bring exactly the right tyre with us.</p>
        </li>
        <li class="area-point">
          <h3>No travel fee on planned jobs</h3>
          <p>Bilsthorpe is three miles away, so there&rsquo;s no travel charge on a planned mobile fitting in {town} &mdash; just the cost of the tyre and the work. Urgent and out-of-hours callouts are charged separately, but agreed up front and never sprung on you on arrival.</p>
        </li>
        <li class="area-point">
          <h3>The same experienced fitter every time</h3>
          <p>It&rsquo;s a sole-operator business. The person who answers the phone is the one who turns up at your door &mdash; whether that&rsquo;s your driveway or a lodge in the woods.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby areas also covered</span>
      <h2>Just outside {town}? We&rsquo;ve still got you</h2>
      <p>Plenty of our regulars are in the surrounding villages and towns. Tap any of these for more, or just give us a call.</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/ollerton/">Ollerton</a>
        <a class="tag" href="/areas/bilsthorpe/">Bilsthorpe</a>
        <a class="tag" href="/areas/rainworth/">Rainworth</a>
        <a class="tag" href="/areas/farnsfield/">Farnsfield</a>
        <a class="tag" href="/areas/mansfield/">Mansfield</a>
        <a class="tag" href="/areas/worksop/">Worksop</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Tyre trouble in {town}?</h2>
      <p class="text-muted-dark">Pick up the phone and you&rsquo;ll have an exact, all-in price and a realistic ETA within minutes.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Tuxford';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 A1 & A57 Tyre Service`}
  description={`24/7 mobile tyre fitting in ${town} and along the A1/A57 junction. 25-minute average ETA from our Bilsthorpe base. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        24/7 mobile tyre fitting across Tuxford and the A1/A57 corridor. 25-minute average ETA from our Bilsthorpe base.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers stick with us</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>Properly local</h3>
          <p>Bilsthorpe to Tuxford is a 20-minute run on a clear day. We&rsquo;re a faster bet than fitters coming up from Newark or down from Doncaster.</p>
        </li>
        <li class="area-point">
          <h3>REACT licensed for A1 emergencies</h3>
          <p>The A1/A57 junction produces regular tyre callouts. Tyre Emergency is REACT licensed and experienced in working safely on fast carriageways when a roadside callout is needed.</p>
        </li>
        <li class="area-point">
          <h3>Cars, vans and caravans covered</h3>
          <p>Whatever type of vehicle you&rsquo;re driving, we source the right tyre before setting off. Cars, SUVs, light vans and caravans all handled on-site.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} catchment</h2>
      <p class="text-muted">A short hop along the A1 in either direction:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/retford/">Retford</a>
        <a class="tag" href="/areas/newark/">Newark</a>
        <a class="tag" href="/areas/worksop/">Worksop</a>
        <a class="tag" href="/areas/blyth/">Blyth</a>
        <a class="tag" href="/areas/lincoln/">Lincoln</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Tyre emergency in {town}?</h2>
      <p class="text-muted-dark">Call us and you&rsquo;ll have a real ETA and a fixed price in no time.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

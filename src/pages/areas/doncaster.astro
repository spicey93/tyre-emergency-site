---
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
const town = 'Doncaster';
---

<BaseLayout
  title={`Mobile Tyre Fitting in ${town} | 24/7 A1(M) & M18 Tyre Service`}
  description={`24/7 mobile tyre fitting and emergency replacement throughout ${town} and along the A1(M)/M18. 45-minute average ETA. Call 01623 325 123.`}
>
  <section class="area-hero">
    <div class="container">
      <span class="eyebrow">{town}</span>
      <h1>Mobile Tyre Fitting in {town}</h1>
      <p class="area-intro">
        Doncaster is at the northern edge of Dean&rsquo;s regular coverage, reached via the A1 from Blyth and Bawtry. Average ETA into central Doncaster is 45 minutes. He covers the city centre, Bessacarr, Cantley, Bentley, the trade and logistics estates around iPort and West Moor Park, and the surrounding villages of Tickhill and Rossington. Emergency replacement, pre-booked fitting, puncture repair &mdash; the job is done on-site wherever the vehicle has stopped.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Call: {phone}
        </a>
        <a class="btn btn-outline" href="/#quote">Get a Quote</a>
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-narrow">
      <span class="eyebrow" style="color: var(--color-accent);">Why Choose Us in {town}</span>
      <h2>Three reasons {town} drivers call us out</h2>
      <ul class="area-points">
        <li class="area-point">
          <h3>Trade and business sites welcome</h3>
          <p>iPort and the wider logistics estate generate regular van and car tyre work. Dean is used to working on large commercial sites and gets the job done with minimum disruption.</p>
        </li>
        <li class="area-point">
          <h3>Fixed pricing, no distance loading</h3>
          <p>Even at the far edge of the coverage area, the quote is fixed and all-in. The price you hear on the phone is the price you pay &mdash; no extras for the extra miles.</p>
        </li>
        <li class="area-point">
          <h3>REACT licensed for motorway emergencies</h3>
          <p>The A1(M) and M18 produce regular tyre callouts. Dean is REACT licensed and qualified to work safely on motorways and fast dual carriageways.</p>
        </li>
      </ul>
    </div>
  </section>

  <section class="section section-darker">
    <div class="container container-narrow">
      <span class="eyebrow">Nearby Areas Also Covered</span>
      <h2>Across the {town} region</h2>
      <p class="text-muted">If you&rsquo;re heading south on the A1 or coming down the M18, we&rsquo;re in your route:</p>
      <div class="tag-cloud">
        <a class="tag" href="/areas/blyth/">Blyth</a>
        <a class="tag" href="/areas/retford/">Retford</a>
        <a class="tag" href="/areas/worksop/">Worksop</a>
        <a class="tag" href="/areas/chesterfield/">Chesterfield</a>
        <a class="tag" href="/areas/tuxford/">Tuxford</a>
      </div>
    </div>
  </section>

  <section class="section section-light service-cta-section">
    <div class="container container-narrow text-center">
      <h2>Tyre emergency in {town}?</h2>
      <p class="text-muted-dark">Phone the line and we&rsquo;ll dispatch the closest engineer with a fixed quoted price for the job.</p>
      <a class="btn btn-primary btn-call" href={telHref}>
        <span aria-hidden="true">&#9742;</span> Call {phone}
      </a>
    </div>
  </section>
</BaseLayout>

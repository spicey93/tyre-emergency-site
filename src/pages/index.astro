---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { googleRating, businessStats } from '../data/reviews';
import { defaultPhone, defaultTelHref, defaultPhoneIntl } from '../data/business';

const phone = defaultPhone;
const telHref = defaultTelHref;

const services = [
  {
    title: 'Emergency Tyre Replacement',
    description: 'Stuck with a flat at the worst possible time? We\'ll be there at a moment\'s notice with a fitted replacement, day or night.',
    href: '/services/emergency-tyre-replacement/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v6"/><path d="m4.93 10.93 4.24 4.24"/><path d="M2 18h6"/><path d="m4.93 25.07 4.24-4.24" transform="translate(0 -7)"/><circle cx="12" cy="12" r="9"/></svg>',
  },
  {
    title: 'Mobile Tyre Fitting',
    description: 'Everything a tyre shop does — properly fitted, balanced and torqued — done from the comfort of your own home.',
    href: '/services/mobile-tyre-fitting/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/><path d="M12 3v3"/><path d="M12 18v3"/><path d="M3 12h3"/><path d="M18 12h3"/></svg>',
  },
  {
    title: 'Mobile Caravan Tyre Fitting',
    description: 'No towing the ‘van anywhere. We come to you and handle motor movers, Tyron bands and the rest with care.',
    href: '/services/mobile-caravan-tyre-fitting/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="16" height="10" rx="2"/><circle cx="9" cy="19" r="2"/><path d="M18 12h4l-2 5h-2"/></svg>',
  },
  {
    title: 'Mobile Tyre Repair',
    description: 'Plenty of life left in the tyre? A proper BS AU159 repair saves you fitting a new one. We bring a spare just in case.',
    href: '/services/mobile-tyre-repair/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a3 3 0 1 1 4.2 4.2l-9.9 9.9-5.7 1.5 1.5-5.7Z"/><path d="m13 8 3 3"/></svg>',
  },
  {
    title: 'Locking Wheel Nut Removal',
    description: 'Damaged or missing locker stopping you getting other work done? Don\'t make it worse — give us a call.',
    href: '/services/locking-wheel-nut-removal/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="11" width="12" height="9" rx="2"/><path d="M9 11V7a3 3 0 0 1 6 0v4"/></svg>',
  },
];

const areas = [
  'Mansfield', 'Nottingham', 'Newark', 'Worksop', 'Chesterfield', 'Doncaster',
  'Lincoln', 'Retford', 'Grantham', 'Southwell', 'Tuxford', 'Blyth',
];

const faqs = [
  {
    question: 'How quickly can you get to me?',
    answer: 'Across most of Nottinghamshire we average around 30 minutes. We always give you a realistic ETA over the phone — not a best-case figure to get you off the call. If we can\'t get to you fast enough, we\'ll tell you straight away rather than have you waiting around.',
  },
  {
    question: 'Are you really 24/7?',
    answer: 'Yes — nights, weekends, Christmas Day, bank holidays, all of it. The phone is answered by a real person every time, not a voicemail or a callback service. Turning up when other people won\'t is a big part of what we do.',
  },
  {
    question: 'Will you have my tyre size?',
    answer: 'We source the right tyre for your vehicle before we set off — confirmed against your reg on the phone and collected from one of our local suppliers on the way. If a particular size needs ordering in we\'ll tell you upfront how that affects the timing.',
  },
  {
    question: 'I don\'t know exactly where I am — is that a problem?',
    answer: 'Not at all. We\'ll send you a quick text and you can share your location straight from your phone. We\'ll see exactly where you are and head over.',
  },
  {
    question: 'Is it safe to wait in my car?',
    answer: 'On a motorway hard shoulder or smart motorway, no — get out of the vehicle, behind the barrier if you can, and call the police on 101 (or 999 if you feel in danger) before you call us. On A-roads, B-roads and at home, stay in the car with hazards on if traffic is moving, or move to a safe verge. We\'ll talk you through it when you ring.',
  },
  {
    question: 'How much does it cost?',
    answer: `The price depends on the tyre, your vehicle, where you are and how urgent it is. We're not the cheapest — we're built around speed, convenience and turning up when we say we will. You'll get an exact, all-in price on the phone before we set off, with no hidden extras when we arrive. As a rough guide, our average all-in price across ${businessStats.jobCount} jobs is around £${businessStats.averagePrice}, but yours could be higher or lower depending on the factors above.`,
  },
  {
    question: 'Do you cover my area?',
    answer: 'We cover the whole of Nottinghamshire and the surrounding counties — Mansfield, Nottingham, Newark, Worksop, Chesterfield, Doncaster, Lincoln, Retford, Grantham, Southwell, Tuxford, Blyth and everywhere in between. Not sure if you\'re in range? Just give us a call. If we genuinely can\'t reach you we\'ll point you towards someone reliable who can.',
  },
  {
    question: 'Cars only, or do you do caravans and vans too?',
    answer: 'Cars, SUVs, vans, caravans, motorhomes and trailers — all of it. Caravans in particular are made for mobile fitting: no towing the \'van anywhere and no risk of an inexperienced fitter damaging your motor mover or Tyron bands. What we don\'t cover is motorbikes, scooters, agricultural vehicles or HGVs — for any of those you\'ll need a specialist who\'s properly set up for that kind of work.',
  },
  {
    question: 'How do I pay?',
    answer: 'All major debit and credit cards via contactless or chip-and-pin, plus Apple Pay and Google Pay. Nothing is paid up front — you pay once the work\'s done and you\'re happy.',
  },
];
---

<BaseLayout
  title="Tyre Emergency Ltd | 24/7 Mobile Tyre Fitting Nottinghamshire"
  description={`Emergency mobile tyre fitting and repair across Nottinghamshire and the East Midlands. 30-minute average ETA, REACT licensed technicians, 5.0 stars on Google. Call ${phone}.`}
  jsonLd={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    '@id': 'https://tyreemergencyltd.co.uk/#business',
    name: 'Tyre Emergency Ltd',
    description: '24/7 emergency mobile tyre fitting, replacement and repair across Nottinghamshire and the wider East Midlands.',
    url: 'https://tyreemergencyltd.co.uk/',
    telephone: defaultPhoneIntl,
    email: 'contact@tyreemergency.com',
    image: 'https://tyreemergencyltd.co.uk/og-image.jpg',
    priceRange: '££',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Bilsthorpe',
      addressLocality: 'Newark',
      addressRegion: 'Nottinghamshire',
      postalCode: 'NG22 8GA',
      addressCountry: 'GB',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 53.182,
      longitude: -1.012,
    },
    areaServed: areas.map((a) => ({ '@type': 'City', name: a })),
    openingHoursSpecification: [{
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
      opens: '00:00',
      closes: '23:59',
    }],
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: googleRating.ratingValue,
      reviewCount: String(googleRating.reviewCount),
      bestRating: '5',
      worstRating: '1',
    },
    sameAs: [
      'https://www.facebook.com/tyreemergencyltd',
      'https://www.instagram.com/tyreemergencyltd',
      'https://www.youtube.com/@TyreEmergencyLtd',
      'https://www.tiktok.com/@TyreEmergencyLtd',
      'https://twitter.com/tyre_emergency',
      'https://g.page/r/UglmQxsSPUYKmNpQM',
    ],
  })}
>
  <HeroSection
    eyebrow="24/7 Mobile Tyre Fitting · Nottinghamshire"
    title="Flat Tyre?<br />We&rsquo;ll Be There In <span class='accent'>30 Minutes</span>."
    subtitle="Mobile tyre fitting across Nottinghamshire. We come to you, day or night."
    ctaPhone={phone}
    ctaCallLabel="Call 24/7"
    secondaryCta={{ label: 'Get an instant price', href: '/quote/' }}
    bgImage="/images/tyre-emergency-action.webp"
    bgImageAlt="Tyre Emergency Ltd service van pulled up next to a car with a flat tyre on a wet roadside"
    trustItems={[
      { strong: String(googleRating.reviewCount), label: '★★★★★ Google Reviews' },
      { strong: 'REACT', label: 'Licensed & Fully Insured' },
      { strong: 'Cars, Vans', label: 'Caravans, Motorhomes, Trailers' },
    ]}
  />

  <!-- Section 2: Social proof -->
  <!-- Section 3: How it works -->
  <section class="section section-light">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">How It Works</span>
        <h2>Back on the road in three steps</h2>
      </div>

      <ol class="steps">
        <li class="step">
          <span class="step-num">01</span>
          <h3>Pick up the phone</h3>
          <p>Ring us 24/7 on <a href={telHref}>{phone}</a> or <a href="/quote/">get an instant price online</a> if it&rsquo;s not urgent. A real person picks up &mdash; no menus, no callback queue.</p>
        </li>
        <li class="step">
          <span class="step-num">02</span>
          <h3>Exact price, realistic ETA</h3>
          <p>Tell us your reg and your location (we&rsquo;ll text if you&rsquo;re not sure where you are) and we&rsquo;ll give you the all-in price and an honest ETA on the spot.</p>
        </li>
        <li class="step">
          <span class="step-num">03</span>
          <h3>Fitted and back on the road</h3>
          <p>We arrive with everything we need, fit it properly to manufacturer torque, and you tap your card when we&rsquo;re done.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- Section 4: Services -->
  <section class="section section-white">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">Services</span>
        <h2>What We Do</h2>
        <p class="section-lede">From a single screw in a tyre to a full caravan job, we&rsquo;re kitted out for the lot &mdash; and we come to you.</p>
      </div>

      <div class="grid grid-3 services-grid">
        {services.map((s) => (
          <ServiceCard title={s.title} description={s.description} icon={s.icon} href={s.href} />
        ))}
      </div>
    </div>
  </section>

  <ReviewsSection variant="light" title="Five Stars. Hundreds of Drivers Rescued." lede="A few words from real customers we&rsquo;ve sorted out &mdash; on the roadside, on the driveway and in the office car park." />

  <!-- Section 5: Coverage -->
  <section class="section section-white">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">Coverage</span>
        <h2>Covering Nottinghamshire and Beyond</h2>
        <p class="section-lede">
          We&rsquo;re based in Bilsthorpe right in the middle of Nottinghamshire, so most of the county is on our doorstep. We regularly run out into Lincolnshire, South Yorkshire and north Derbyshire too &mdash; if you&rsquo;re not sure whether we&rsquo;ll come to you, just give us a ring and we&rsquo;ll tell you straight.
        </p>
      </div>

      <div class="tag-cloud coverage-tags">
        {areas.map((area) => (
          <a class="tag" href={`/areas/${area.toLowerCase()}/`}>{area}</a>
        ))}
      </div>

      <p class="coverage-roads text-center">
        Key roads served: <strong>A1</strong> &middot; <strong>A614</strong> &middot; <strong>M1</strong> &middot; <strong>A60</strong> &middot; <strong>A38</strong> &middot; <strong>A52</strong>
      </p>
    </div>
  </section>

  <!-- Section 6: About -->
  <section class="section section-light">
    <div class="container">
      <div class="about-split">
        <div class="about-split-text">
          <span class="eyebrow">About</span>
          <h2>Founded by Dean Spicer &mdash; A Decade of Roadside Experience</h2>
          <p class="about-bio">
            Dean has been in the tyre trade since he was a teenager &mdash; national chains, independent garages, time in management, and back to being hands-on with the tools. Tyre Emergency Ltd was set up in December 2023 with a simple idea: build a business around speed, convenience and being properly straight with people. Because it&rsquo;s a sole-operator outfit, Dean answers every call, gives every quote and fits every tyre himself. No rota, no agency cover &mdash; the same experienced fitter whether you ring at noon or midnight. Hundreds of five-star reviews on Google say the rest.
          </p>
          <div class="badge-row about-badges">
            <span class="badge">REACT Licensed</span>
            <span class="badge">In the Trade Since His Teens</span>
            <span class="badge">Fully Insured</span>
          </div>
        </div>
        <div class="about-split-image">
          <img
            src="/images/emergency-tyre-fitting.webp"
            alt="Dean Spicer fitting a tyre using a torque wrench on a customer's vehicle"
            width="1600"
            height="900"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>


  <!-- Section: Recent jobs gallery -->
  <section class="section section-white">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">On the job</span>
        <h2>What we&rsquo;ve been up to</h2>
      </div>
      <div class="gallery-wrap">
        <script is:inline async src="https://elfsightcdn.com/platform.js"></script>
        <div class="elfsight-app-2c14d44d-fbf3-47da-9bff-790f824a47a3" data-elfsight-app-lazy></div>
      </div>
    </div>
  </section>

  <!-- Section 7: FAQ -->
  <section class="section section-light">
    <div class="container">
      <div class="text-center">
        <span class="eyebrow">FAQ</span>
        <h2>Common Questions</h2>
      </div>
      <FAQAccordion items={faqs} />
    </div>
  </section>

  <!-- Section 8: Instant price CTA -->
  <section class="section section-white service-cta-section" id="quote">
    <div class="container container-narrow text-center">
      <span class="eyebrow">Instant price</span>
      <h2>Get a price for your job</h2>
      <p class="text-muted-dark">Tell us what you need and where you are. A few quick questions and we&rsquo;ll show you a price &mdash; book a slot in the same flow.</p>
      <div class="cta-row" style="justify-content: center;">
        <a class="btn btn-primary" href="/quote/">Get an instant price</a>
        <a class="btn btn-outline-dark btn-call" href={telHref}>
          <span aria-hidden="true">&#9742;</span> Or call: {phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-lede {
    max-width: 60ch;
    margin: 0 auto 3rem;
    font-size: 1.1rem;
    color: inherit;
    opacity: 0.85;
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .step {
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  .step-num {
    display: block;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 4rem;
    color: var(--color-text-dark);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .step h3 {
    font-size: 1.2rem;
    margin-bottom: 0.6rem;
    color: var(--color-text-dark);
  }

  .step p {
    color: var(--color-text-muted-dark);
    margin: 0;
    font-size: 0.95rem;
  }

  .step a {
    color: var(--color-text-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .step a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .steps {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  .services-grid {
    margin-top: 1rem;
  }

  .coverage-tags {
    margin-bottom: 2.5rem;
  }

  .coverage-roads {
    color: var(--color-text-muted-dark);
    font-size: 1rem;
    margin: 0;
  }

  .coverage-roads strong {
    color: var(--color-text-dark);
    font-family: var(--font-display);
    font-size: 1.1rem;
  }

  .about-bio {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-muted-dark);
    margin-bottom: 2rem;
  }

  .about-badges {
    justify-content: flex-start;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const phone = '0330 133 9311';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;
---

<BaseLayout
  title="Message Received | Tyre Emergency Ltd"
  description="Thank you for getting in touch with Tyre Emergency Ltd. We'll be back to you shortly."
>
  <section class="thankyou-hero">
    <div class="container">
      <div class="thankyou-inner">
        <span class="thankyou-icon" aria-hidden="true">&#10003;</span>
        <h1>Message received.</h1>
        <p>Thanks for getting in touch. Dean will get back to you as soon as possible &mdash; usually within the hour during the day.</p>
        <p class="thankyou-emergency">If this is an emergency, don&rsquo;t wait for a reply &mdash; call directly and he&rsquo;ll answer straight away.</p>
        <div class="cta-row">
          <a class="btn btn-primary btn-call" href={telHref}>
            <span aria-hidden="true">&#9742;</span> Call Now: {phone}
          </a>
          <a class="btn btn-outline" href="/">Back to Home</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .thankyou-hero {
    min-height: calc(100vh - 72px);
    display: flex;
    align-items: center;
    background-color: var(--color-bg-white);
    color: var(--color-text-dark);
    padding: 4rem 0;
  }

  .thankyou-inner {
    max-width: 580px;
  }

  .thankyou-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: var(--color-accent);
    color: white;
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .thankyou-inner h1 {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    margin-bottom: 1rem;
  }

  .thankyou-inner p {
    color: var(--color-text-muted-dark);
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .thankyou-emergency {
    padding: 0.9rem 1.1rem;
    border-left: 3px solid var(--color-accent);
    background-color: rgba(255, 45, 45, 0.07);
    border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: 2rem !important;
    color: var(--color-text-dark) !important;
    font-size: 0.95rem !important;
  }
</style>

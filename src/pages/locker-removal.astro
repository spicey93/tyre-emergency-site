---
import LandingLayout from '../layouts/LandingLayout.astro';

const phone = '01623 325 123';
const telHref = `tel:${phone.replace(/\s+/g, '')}`;

const areas = [
  'Mansfield', 'Nottingham', 'Newark', 'Worksop', 'Chesterfield', 'Doncaster',
  'Lincoln', 'Retford', 'Grantham', 'Southwell', 'Tuxford', 'Blyth',
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Mobile Locking Wheel Nut Removal',
  serviceType: 'Locking Wheel Nut Removal',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Tyre Emergency Ltd',
    telephone: '+441623325123',
    url: 'https://tyreemergencyltd.co.uk/',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Bilsthorpe',
      addressLocality: 'Newark',
      addressRegion: 'Nottinghamshire',
      postalCode: 'NG22 8GA',
      addressCountry: 'GB',
    },
  },
  description: 'Mobile locking wheel nut removal across Nottinghamshire and the East Midlands. Lost keys, stripped patterns, seized nuts — non-destructive specialist extraction on your driveway or at the garage. Same-day slots most days.',
  url: 'https://tyreemergencyltd.co.uk/locker-removal/',
  image: 'https://tyreemergencyltd.co.uk/images/locking-wheel-nut-removal.webp',
  areaServed: areas.map((a) => ({ '@type': 'City', name: a })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '478',
    bestRating: '5',
    worstRating: '1',
  },
};
---

<LandingLayout
  title="Locking Wheel Nut Removal Nottinghamshire | Lost Key, Stripped Locker"
  description="Lost the locker key, stripped the pattern, seized on the stud — we get them off. Mobile locking wheel nut removal across Nottinghamshire, same-day slots most days. Specialist extraction kit, hundreds of jobs done. Call 01623 325 123."
  jsonLd={JSON.stringify(jsonLd)}
>
  <!-- Slim brand bar — no nav, just logo + click-to-call -->
  <header class="lp-bar">
    <div class="lp-bar-inner">
      <a href="/" class="lp-logo" aria-label="Tyre Emergency Ltd home">
        <img src="/logo.png" alt="Tyre Emergency Ltd" width="160" height="48" loading="eager" fetchpriority="high" />
      </a>
      <a class="lp-bar-call" href={telHref} data-call="bar">
        <span aria-hidden="true">&#9742;</span>
        <span class="lp-bar-call-number">{phone}</span>
        <span class="lp-bar-call-short">Call now</span>
      </a>
    </div>
  </header>

  <!-- HERO -->
  <section class="lp-hero">
    <img
      class="lp-hero-bg"
      src="/images/locking-wheel-nut-removal.webp"
      alt="Close-up of a stripped locking wheel nut being extracted on an alloy wheel"
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="container lp-hero-inner">
      <span class="lp-eyebrow">Mobile Locking Wheel Nut Removal &middot; Nottinghamshire</span>
      <h1>Lost the key?<br />Stripped the locker?<br /><span class="lp-eta">We&rsquo;ll get it off.</span></h1>
      <p class="lp-sub">
        Lost keys, stripped patterns, seized nuts &mdash; we get them off. Most jobs sorted in 15&ndash;30 minutes once we&rsquo;re with you.
      </p>

      <a class="lp-call-primary" href={telHref} data-call="hero">
        <span class="lp-call-icon" aria-hidden="true">&#9742;</span>
        <span class="lp-call-stack">
          <small>Call for a price &mdash; same-day slots most days</small>
          <strong>{phone}</strong>
        </span>
      </a>

      <ul class="lp-trust">
        <li><strong>478</strong> &#9733;&#9733;&#9733;&#9733;&#9733; Google reviews</li>
        <li><strong>Specialist</strong> extraction kit on the van</li>
        <li><strong>15&ndash;30 min</strong> typical job time</li>
      </ul>
    </div>
  </section>

  <!-- WHAT YOU GET -->
  <section class="lp-block lp-light">
    <div class="container container-narrow">
      <h2 class="lp-block-title">When you call, here&rsquo;s what happens</h2>
      <ol class="lp-steps">
        <li>
          <span class="lp-step-num" aria-hidden="true">1</span>
          <div>
            <h3>We answer the phone</h3>
            <p>A real person, every time. Tell us your reg, where the car is (driveway, garage, work car park) and what&rsquo;s up with the locker &mdash; lost key, stripped pattern, seized on the stud. We&rsquo;ll know straight away whether it&rsquo;s a job we can take.</p>
          </div>
        </li>
        <li>
          <span class="lp-step-num" aria-hidden="true">2</span>
          <div>
            <h3>Honest price agreed up front</h3>
            <p>Total you&rsquo;ll pay &mdash; agreed on the call, no surprises when we arrive. We&rsquo;ll book you a slot that suits, often same-day. If the locker has had a previous attempt at it, we&rsquo;d rather chat that one through first so the price stays honest.</p>
          </div>
        </li>
        <li>
          <span class="lp-step-num" aria-hidden="true">3</span>
          <div>
            <h3>Lockers off, standard nuts on, you tap your card</h3>
            <p>The right extractor out of the kit, locker off, replacement nut torqued to the manufacturer&rsquo;s figure. Card, Apple Pay or Google Pay when the job&rsquo;s done.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ONE STRONG REVIEW -->
  <section class="lp-block lp-dark">
    <div class="container container-narrow">
      <figure class="lp-review">
        <div class="lp-stars" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote>
          <p>&ldquo;I called him and he was with me within the hour, all sorted and road worthy again. I would absolutely recommend this young man, who is a complete professional in his field, mannerly and genuine.&rdquo;</p>
        </blockquote>
        <figcaption>
          <strong>Lesley Park</strong> &middot; Newark &middot; via Google
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- WHEN PEOPLE CALL US -->
  <section class="lp-block lp-light">
    <div class="container container-narrow">
      <h2 class="lp-block-title">The kind of jobs we get called for</h2>
      <div class="lp-scenarios">
        <article class="lp-scenario">
          <h3>Booked in for tyres &mdash; locker key&rsquo;s missing</h3>
          <p>You&rsquo;ve gone to get tyres or other work done and the key isn&rsquo;t in the car. Without it, no garage will touch the wheel and the job stalls. We come out, get the locker off, the rest of the work carries on.</p>
        </article>
        <article class="lp-scenario">
          <h3>Stripped or rounded pattern</h3>
          <p>A previous garage put an air gun on it and chewed the pattern. The key now spins freely. Our extractors are made for exactly this &mdash; we&rsquo;ll get it off and a standard nut back on.</p>
        </article>
        <article class="lp-scenario">
          <h3>Stuck on a ramp at the garage</h3>
          <p>Car&rsquo;s sitting on a ramp somewhere and the whole job is paused waiting on a locking nut. We&rsquo;ll come to the garage, get it sorted, and let them carry on.</p>
        </article>
        <article class="lp-scenario">
          <h3>Seized on the stud, key still fits</h3>
          <p>Key fits but the nut won&rsquo;t move &mdash; corroded after a few winters of salt. We can usually heat, penetrate and turn it without going to full extraction.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- REASSURANCE -->
  <section class="lp-block lp-dark">
    <div class="container container-narrow">
      <div class="lp-card lp-card-dark">
        <h2>Not sure exactly what&rsquo;s wrong?</h2>
        <p>Most people aren&rsquo;t &mdash; locking nuts only get noticed when something&rsquo;s gone wrong with them. Tell us what you can see and we&rsquo;ll talk you through it on the call. Two minutes on the phone and we&rsquo;ll know whether it&rsquo;s a five-minute job or one we&rsquo;d rather take a proper look at.</p>
        <p class="lp-card-note">
          <strong>One we can&rsquo;t do:</strong> if the bolt itself has snapped (not the locker, the stud underneath), that&rsquo;s a workshop job &mdash; we&rsquo;ll tell you straight rather than waste your time.
        </p>
      </div>
    </div>
  </section>

  <!-- COVERAGE -->
  <section class="lp-block lp-light">
    <div class="container">
      <h2 class="lp-block-title text-center">Covering Nottinghamshire &amp; the East Midlands</h2>
      <p class="lp-coverage-lede lp-coverage-lede-light text-center">
        Based in Bilsthorpe, NG22 &mdash; right in the middle of the county. Booked jobs across the region, every day of the week.
      </p>
      <ul class="lp-area-list lp-area-list-light">
        {areas.map((a) => <li>{a}</li>)}
      </ul>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="lp-block lp-cta">
    <div class="container container-narrow text-center">
      <h2>Ready to get the locker off? Pick up the phone.</h2>
      <p>One call, one honest price, one job done properly.</p>
      <a class="lp-call-primary lp-call-primary-large" href={telHref} data-call="footer">
        <span class="lp-call-icon" aria-hidden="true">&#9742;</span>
        <span class="lp-call-stack">
          <small>Call us</small>
          <strong>{phone}</strong>
        </span>
      </a>
      <p class="lp-fineprint">Tyre Emergency Ltd &middot; Bilsthorpe NG22 8GA &middot; Company No. 15362025 &middot; VAT GB456597051</p>
    </div>
  </section>

  <!-- STICKY MOBILE CALL BAR -->
  <a class="lp-sticky-call" href={telHref} data-call="sticky">
    <span class="lp-call-icon" aria-hidden="true">&#9742;</span>
    <span class="lp-call-stack">
      <small>Call us</small>
      <strong>{phone}</strong>
    </span>
  </a>
</LandingLayout>

<style>
  /* ============================================================
     Slim brand bar (replaces full site header)
     ============================================================ */
  .lp-bar {
    background-color: var(--color-bg-dark);
    border-bottom: 1px solid var(--color-border);
  }

  .lp-bar-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.6rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 60px;
  }

  .lp-logo img {
    height: 40px;
    width: auto;
    display: block;
  }

  .lp-bar-call {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.95rem;
    background-color: var(--color-accent);
    color: var(--color-text);
    border-radius: var(--radius);
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.04em;
    font-size: 1rem;
    transition: background-color var(--transition);
  }

  .lp-bar-call:hover,
  .lp-bar-call:focus-visible {
    background-color: var(--color-accent-dark);
    color: var(--color-text);
  }

  .lp-bar-call-short {
    display: none;
  }

  @media (max-width: 480px) {
    .lp-logo img {
      height: 34px;
    }
    .lp-bar-call-number {
      display: none;
    }
    .lp-bar-call-short {
      display: inline;
    }
  }

  /* ============================================================
     Hero
     ============================================================ */
  .lp-hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background-color: var(--color-bg);
    color: var(--color-text);
    padding: 3.5rem 0 4rem;
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .lp-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    z-index: -2;
  }

  .lp-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      100deg,
      rgba(26, 26, 29, 0.96) 0%,
      rgba(26, 26, 29, 0.9) 30%,
      rgba(26, 26, 29, 0.62) 60%,
      rgba(26, 26, 29, 0.25) 90%
    );
  }

  .lp-hero-inner {
    max-width: 880px;
  }

  .lp-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .lp-hero h1 {
    font-size: clamp(2.2rem, 6.5vw, 4.6rem);
    line-height: 1;
    margin: 0 0 1.25rem;
    max-width: 18ch;
  }

  .lp-eta {
    color: var(--color-accent);
    white-space: nowrap;
  }

  .lp-sub {
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  /* ============================================================
     Big call CTA (used in hero + final CTA + sticky)
     ============================================================ */
  .lp-call-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.95rem;
    padding: 1rem 1.5rem;
    background-color: var(--color-accent);
    color: var(--color-text);
    border-radius: var(--radius);
    text-decoration: none;
    box-shadow: 0 14px 32px -16px rgba(255, 45, 45, 0.7);
    transition: background-color var(--transition), transform var(--transition), box-shadow var(--transition);
    min-height: 64px;
  }

  .lp-call-primary:hover,
  .lp-call-primary:focus-visible {
    background-color: var(--color-accent-dark);
    color: var(--color-text);
    transform: translateY(-1px);
    box-shadow: 0 18px 38px -16px rgba(255, 45, 45, 0.8);
  }

  .lp-call-primary-large {
    padding: 1.15rem 1.8rem;
    min-height: 72px;
  }

  .lp-call-icon {
    font-size: 1.6rem;
    line-height: 1;
  }

  .lp-call-stack {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.05;
  }

  .lp-call-stack small {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    opacity: 0.85;
    margin-bottom: 0.25rem;
  }

  .lp-call-stack strong {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.55rem;
    letter-spacing: 0.02em;
  }

  /* ============================================================
     Trust strip
     ============================================================ */
  .lp-trust {
    list-style: none;
    padding: 0;
    margin: 1.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.25rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .lp-trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .lp-trust strong {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1.05rem;
    margin-right: 0.15rem;
  }

  /* ============================================================
     Section blocks
     ============================================================ */
  .lp-block {
    padding: 4rem 0;
  }

  @media (max-width: 768px) {
    .lp-block {
      padding: 3rem 0;
    }
  }

  .lp-light {
    background-color: var(--color-bg-light);
    color: var(--color-text-dark);
  }

  .lp-light h2,
  .lp-light h3 {
    color: var(--color-text-dark);
  }

  .lp-dark {
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  .lp-block-title {
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    margin: 0 0 1.5rem;
  }

  /* ============================================================
     Steps
     ============================================================ */
  .lp-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }

  .lp-steps li {
    display: flex;
    gap: 1.1rem;
    align-items: flex-start;
  }

  .lp-step-num {
    flex: 0 0 auto;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background-color: var(--color-text-dark);
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.15rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.15rem;
  }

  .lp-steps h3 {
    font-size: 1.15rem;
    margin: 0 0 0.4rem;
  }

  .lp-steps p {
    margin: 0;
    color: var(--color-text-muted-dark);
    line-height: 1.65;
    font-size: 1rem;
  }

  /* ============================================================
     Review
     ============================================================ */
  .lp-review {
    margin: 0;
    padding: 2rem;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-align: center;
  }

  .lp-stars {
    color: var(--color-star);
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    margin-bottom: 0.85rem;
  }

  .lp-review blockquote {
    margin: 0 0 1rem;
  }

  .lp-review p {
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
  }

  .lp-review figcaption {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .lp-review figcaption strong {
    color: var(--color-text);
  }

  /* ============================================================
     Scenarios grid
     ============================================================ */
  .lp-scenarios {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
    margin: 0;
  }

  .lp-scenario {
    padding: 1.5rem 1.4rem;
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
  }

  .lp-scenario h3 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }

  .lp-scenario p {
    margin: 0;
    color: var(--color-text-muted-dark);
    line-height: 1.6;
    font-size: 0.97rem;
  }

  /* ============================================================
     Reassurance card
     ============================================================ */
  .lp-card {
    padding: 2rem;
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
  }

  .lp-card-dark {
    background-color: var(--color-bg-elevated);
    border-color: var(--color-border);
    color: var(--color-text);
  }

  .lp-card h2 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    margin: 0 0 0.75rem;
  }

  .lp-card-dark h2 {
    color: var(--color-text);
  }

  .lp-card p {
    color: var(--color-text-muted-dark);
    line-height: 1.7;
    margin: 0 0 0.85rem;
  }

  .lp-card-dark p {
    color: var(--color-text-muted);
  }

  .lp-card-note {
    padding: 0.9rem 1.1rem;
    border-left: 3px solid var(--color-accent);
    background-color: rgba(255, 45, 45, 0.08);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-size: 0.95rem;
  }

  /* ============================================================
     Coverage strip
     ============================================================ */
  .lp-coverage-lede {
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0 auto 2rem;
  }

  .lp-coverage-lede-light {
    color: var(--color-text-muted-dark);
  }

  .lp-area-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }

  .lp-area-list li {
    padding: 0.5rem 0.95rem;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.92rem;
    color: var(--color-text);
  }

  .lp-area-list-light li {
    background-color: var(--color-bg-white);
    border-color: var(--color-border-light);
    color: var(--color-text-dark);
  }

  /* ============================================================
     Final CTA
     ============================================================ */
  .lp-cta {
    background-color: var(--color-bg-dark);
    color: var(--color-text);
    padding: 4.5rem 0 3.5rem;
  }

  .lp-cta h2 {
    color: var(--color-text);
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin: 0 0 0.85rem;
  }

  .lp-cta p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin: 0 0 2rem;
  }

  .lp-cta .lp-call-primary {
    margin: 0 auto;
  }

  .lp-fineprint {
    margin-top: 2rem !important;
    font-size: 0.8rem !important;
    color: var(--color-text-muted) !important;
    opacity: 0.7;
  }

  /* ============================================================
     Sticky mobile call bar
     ============================================================ */
  .lp-sticky-call {
    display: none;
    position: fixed;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.75rem;
    z-index: 80;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    padding: 0.95rem 1.1rem;
    background-color: var(--color-accent);
    color: var(--color-text);
    border-radius: var(--radius);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.45), 0 12px 26px -10px rgba(255, 45, 45, 0.6);
    text-decoration: none;
    min-height: 60px;
  }

  .lp-sticky-call:hover,
  .lp-sticky-call:focus-visible {
    background-color: var(--color-accent-dark);
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .lp-sticky-call {
      display: inline-flex;
    }
    /* Make sure final CTA is not hidden behind sticky bar */
    .lp-cta {
      padding-bottom: 6.5rem;
    }
  }
</style>

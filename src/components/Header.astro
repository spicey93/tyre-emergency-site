---
export interface Props {
  phone: string;
}

const { phone } = Astro.props as Props;
const telHref = `tel:${phone.replace(/\s+/g, '')}`;

const services = [
  { href: '/services/emergency-tyre-replacement/', label: 'Emergency Tyre Replacement' },
  { href: '/services/mobile-tyre-fitting/', label: 'Mobile Tyre Fitting' },
  { href: '/services/mobile-caravan-tyre-fitting/', label: 'Mobile Caravan Tyre Fitting' },
  { href: '/services/mobile-tyre-repair/', label: 'Mobile Tyre Repair' },
  { href: '/services/locking-wheel-nut-removal/', label: 'Locking Wheel Nut Removal' },
];

const areas = [
  { href: '/areas/mansfield/', label: 'Mansfield' },
  { href: '/areas/nottingham/', label: 'Nottingham' },
  { href: '/areas/newark/', label: 'Newark' },
  { href: '/areas/worksop/', label: 'Worksop' },
  { href: '/areas/chesterfield/', label: 'Chesterfield' },
  { href: '/areas/doncaster/', label: 'Doncaster' },
  { href: '/areas/lincoln/', label: 'Lincoln' },
  { href: '/areas/retford/', label: 'Retford' },
  { href: '/areas/grantham/', label: 'Grantham' },
  { href: '/areas/southwell/', label: 'Southwell' },
  { href: '/areas/tuxford/', label: 'Tuxford' },
  { href: '/areas/blyth/', label: 'Blyth' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Tyre Emergency Ltd home">
      <img
        src="/logo.png"
        alt="Tyre Emergency Ltd"
        width="177"
        height="54"
        loading="eager"
        fetchpriority="high"
      />
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <button
        type="button"
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="primary-menu"
      >
        <span class="visually-hidden">Toggle menu</span>
        <span class="nav-toggle-bar" aria-hidden="true"></span>
        <span class="nav-toggle-bar" aria-hidden="true"></span>
        <span class="nav-toggle-bar" aria-hidden="true"></span>
      </button>

      <ul id="primary-menu" class="nav-menu">
        <li><a href="/">Home</a></li>

        <li class="has-dropdown">
          <a href="/services/" class="nav-parent">
            Services
            <span class="caret" aria-hidden="true">&#9662;</span>
          </a>
          <button type="button" class="dropdown-toggle" aria-expanded="false" aria-controls="services-submenu">
            <span class="visually-hidden">Toggle Services submenu</span>
            <span class="caret" aria-hidden="true">&#9662;</span>
          </button>
          <ul id="services-submenu" class="dropdown-menu">
            <li class="dropdown-overview"><a href="/services/">All services</a></li>
            {services.map((s) => (
              <li><a href={s.href}>{s.label}</a></li>
            ))}
          </ul>
        </li>

        <li class="has-dropdown">
          <a href="/areas/" class="nav-parent">
            Areas
            <span class="caret" aria-hidden="true">&#9662;</span>
          </a>
          <button type="button" class="dropdown-toggle" aria-expanded="false" aria-controls="areas-submenu">
            <span class="visually-hidden">Toggle Areas submenu</span>
            <span class="caret" aria-hidden="true">&#9662;</span>
          </button>
          <ul id="areas-submenu" class="dropdown-menu dropdown-menu-cols">
            <li class="dropdown-overview"><a href="/areas/">All areas covered</a></li>
            {areas.map((a) => (
              <li><a href={a.href}>{a.label}</a></li>
            ))}
          </ul>
        </li>

        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
      </ul>
    </nav>

    <a class="header-phone" href={telHref}>
      <span aria-hidden="true" class="phone-icon">&#9742;</span>
      <span class="phone-number">{phone}</span>
    </a>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('primary-menu');
  const isMobile = () => window.matchMedia('(max-width: 900px)').matches;

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      menu.classList.toggle('is-open');
      document.body.classList.toggle('nav-open', !open);
    });

    menu.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
      link.addEventListener('click', () => {
        // On mobile, the parent (.nav-parent) toggles the dropdown rather
        // than navigating, so we mustn't close the whole menu when it's tapped.
        if (link.classList.contains('nav-parent') && isMobile()) return;
        toggle.setAttribute('aria-expanded', 'false');
        menu.classList.remove('is-open');
        document.body.classList.remove('nav-open');
      });
    });
  }

  // On mobile, tapping the parent link ("Services" / "Areas") expands the
  // dropdown in place instead of navigating — saves users from hunting for
  // the small caret button.
  document.querySelectorAll<HTMLAnchorElement>('.nav-parent').forEach((parent) => {
    parent.addEventListener('click', (event) => {
      if (!isMobile()) return;
      event.preventDefault();
      const wrapper = parent.closest('.has-dropdown');
      if (!wrapper) return;
      const isOpen = wrapper.classList.toggle('is-open');
      const tog = wrapper.querySelector<HTMLButtonElement>('.dropdown-toggle');
      if (tog) tog.setAttribute('aria-expanded', String(isOpen));
    });
  });

  // Caret button still works for keyboard users and for explicit toggling.
  document.querySelectorAll<HTMLButtonElement>('.dropdown-toggle').forEach((btn) => {
    btn.addEventListener('click', (event) => {
      event.preventDefault();
      const wrapper = btn.closest('.has-dropdown');
      if (!wrapper) return;
      const isOpen = wrapper.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(isOpen));
    });
  });

  // Close any open dropdown when clicking outside (desktop)
  document.addEventListener('click', (event) => {
    const target = event.target as Element | null;
    if (!target) return;
    document.querySelectorAll('.has-dropdown.is-open').forEach((el) => {
      if (!el.contains(target)) {
        el.classList.remove('is-open');
        const t = el.querySelector<HTMLButtonElement>('.dropdown-toggle');
        if (t) t.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 90;
    background-color: rgba(26, 26, 29, 0.96);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 72px;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .logo img {
    height: 54px;
    width: auto;
    display: block;
  }

  .primary-nav {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
  }

  .nav-toggle-bar {
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
  }

  .nav-menu {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-menu > li > a,
  .nav-menu .nav-parent {
    color: var(--color-text);
    font-weight: 500;
    font-size: 0.95rem;
    padding: 0.5rem 0;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .nav-menu > li > a:hover,
  .nav-menu .nav-parent:hover {
    color: var(--color-accent);
  }

  .has-dropdown {
    position: relative;
  }

  .has-dropdown .caret {
    font-size: 0.7rem;
    transition: transform var(--transition);
  }

  .dropdown-toggle {
    display: none;
  }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 280px;
    background-color: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    list-style: none;
    margin: 0;
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity var(--transition), transform var(--transition), visibility 0s linear var(--transition);
    box-shadow: 0 16px 40px -18px rgba(0, 0, 0, 0.6);
    z-index: 95;
  }

  /* Invisible bridge so the cursor stays inside the hover region
     when crossing the gap between parent and dropdown. */
  .dropdown-menu::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: -0.6rem;
    height: 0.6rem;
    background: transparent;
  }

  .has-dropdown::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -0.6rem;
    height: 0.6rem;
    background: transparent;
    pointer-events: none;
  }

  .has-dropdown:hover::after,
  .has-dropdown:focus-within::after {
    pointer-events: auto;
  }

  .has-dropdown:hover > .dropdown-menu,
  .has-dropdown:focus-within > .dropdown-menu,
  .has-dropdown.is-open > .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity var(--transition), transform var(--transition), visibility 0s;
  }

  .has-dropdown:hover > .nav-parent .caret,
  .has-dropdown:focus-within > .nav-parent .caret,
  .has-dropdown.is-open > .nav-parent .caret {
    transform: rotate(180deg);
  }

  .dropdown-menu li a {
    display: block;
    padding: 0.55rem 0.85rem;
    color: var(--color-text);
    font-size: 0.92rem;
    border-radius: var(--radius);
    transition: background-color var(--transition), color var(--transition);
  }

  .dropdown-menu li a:hover,
  .dropdown-menu li a:focus-visible {
    background-color: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
  }

  .dropdown-overview {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.4rem;
    padding-bottom: 0.4rem;
  }

  .dropdown-overview a {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem !important;
    color: var(--color-accent) !important;
  }

  .dropdown-menu-cols {
    min-width: 360px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .dropdown-menu-cols .dropdown-overview {
    grid-column: 1 / -1;
  }

  .header-phone {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background-color: var(--color-accent);
    color: var(--color-text);
    border-radius: var(--radius);
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.04em;
    font-size: 1rem;
    transition: background-color var(--transition);
  }

  .header-phone:hover {
    background-color: var(--color-accent-dark);
    color: var(--color-text);
  }

  .phone-icon {
    font-size: 1.1rem;
  }

  @media (max-width: 900px) {
    .header-inner {
      gap: 0.75rem;
    }
    .logo img {
      height: 44px;
    }
    .header-phone .phone-number {
      display: none;
    }
    .header-phone {
      padding: 0.6rem 0.8rem;
    }
    .nav-toggle {
      display: inline-flex;
    }
    .header-phone {
      display: none;
    }
    .nav-menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background-color: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 1.25rem 1.5rem;
      gap: 0;
      max-height: calc(100vh - 72px);
      overflow-y: auto;
    }
    .nav-menu.is-open {
      display: flex;
    }
    .nav-menu > li {
      border-bottom: 1px solid var(--color-border);
    }
    .nav-menu > li:last-child {
      border-bottom: none;
    }
    .nav-menu > li > a,
    .nav-menu .nav-parent {
      display: block;
      padding: 0.9rem 0;
      font-family: var(--font-display);
      font-size: 1.1rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .has-dropdown {
      position: relative;
    }

    .has-dropdown .nav-parent .caret {
      display: none;
    }

    .dropdown-toggle {
      display: inline-flex;
      position: absolute;
      top: 0.4rem;
      right: 0;
      width: 44px;
      height: 44px;
      align-items: center;
      justify-content: center;
      color: var(--color-text);
      background: transparent;
      border-radius: var(--radius);
    }

    .dropdown-toggle .caret {
      font-size: 0.9rem;
      transition: transform var(--transition);
    }

    .has-dropdown.is-open .dropdown-toggle .caret {
      transform: rotate(180deg);
    }

    .dropdown-menu {
      position: static;
      display: none;
      opacity: 1;
      visibility: visible;
      transform: none;
      transition: none;
      box-shadow: none;
      background-color: transparent;
      border: none;
      padding: 0 0 0.75rem;
      min-width: 0;
      grid-template-columns: 1fr;
      margin: 0;
    }

    .has-dropdown.is-open .dropdown-menu {
      display: block;
    }

    .dropdown-menu-cols {
      display: none;
      grid-template-columns: 1fr 1fr;
    }

    .has-dropdown.is-open .dropdown-menu-cols {
      display: grid;
    }

    .dropdown-menu li a {
      padding: 0.65rem 0.85rem;
      font-size: 0.95rem;
    }

    .dropdown-overview {
      grid-column: 1 / -1;
    }
  }
</style>

---
export interface Props {
  title: string;
  description: string;
  icon: string;
  href: string;
}

const { title, description, icon, href } = Astro.props as Props;
---

<a class="service-card" href={href}>
  <span class="service-icon" aria-hidden="true" set:html={icon} />
  <h3 class="service-title">{title}</h3>
  <p class="service-description">{description}</p>
  <span class="service-link">Learn more <span aria-hidden="true">&rarr;</span></span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 2rem 1.75rem;
    background-color: var(--color-bg-white);
    color: var(--color-text-dark);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    height: 100%;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-text-dark);
    box-shadow: 0 18px 40px -22px rgba(0, 0, 0, 0.35);
    color: var(--color-text-dark);
  }

  .service-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius);
    background-color: rgba(0, 0, 0, 0.06);
    color: var(--color-text-dark);
    margin-bottom: 1.25rem;
  }

  .service-icon :global(svg) {
    width: 28px;
    height: 28px;
  }

  .service-title {
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-dark);
  }

  .service-description {
    color: var(--color-text-muted-dark);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
    flex-grow: 1;
  }

  .service-link {
    color: var(--color-text-dark);
    font-weight: 700;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9rem;
  }

  .service-card:hover .service-link {
    color: var(--color-accent);
  }
</style>

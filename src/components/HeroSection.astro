---
export interface TrustItem {
  strong: string;
  label: string;
}

export interface SecondaryCta {
  label: string;
  href: string;
}

export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  ctaPhone: string;
  ctaCallLabel?: string;
  secondaryCta?: SecondaryCta;
  bgImage: string;
  bgImageAlt?: string;
  trustItems?: TrustItem[];
}

const defaultTrust: TrustItem[] = [
  { strong: '478', label: '★★★★★ Google reviews' },
  { strong: 'REACT', label: 'licensed & fully insured' },
  { strong: '30 min', label: 'average ETA' },
];

const {
  eyebrow,
  title,
  subtitle,
  ctaPhone,
  ctaCallLabel = 'Call now',
  secondaryCta,
  bgImage,
  bgImageAlt = 'Tyre Emergency Ltd service van working at the roadside',
  trustItems = defaultTrust,
} = Astro.props as Props;

const telHref = `tel:${ctaPhone.replace(/\s+/g, '')}`;
---

<section class="hero">
  <img
    class="hero-bg-img"
    src={bgImage}
    alt={bgImageAlt}
    width="1600"
    height="900"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="container hero-inner">
    {eyebrow && <span class="hero-eyebrow">{eyebrow}</span>}
    <h1 set:html={title} />
    {subtitle && <p class="hero-sub" set:html={subtitle} />}

    <div class="hero-cta-row">
      <a class="hero-call" href={telHref} data-call="hero">
        <span class="hero-call-icon" aria-hidden="true">&#9742;</span>
        <span class="hero-call-stack">
          <small>{ctaCallLabel}</small>
          <strong>{ctaPhone}</strong>
        </span>
      </a>
      {secondaryCta && (
        <a class="hero-secondary-btn" href={secondaryCta.href}>
          <span class="hero-secondary-label">{secondaryCta.label}</span>
          <span class="hero-secondary-arrow" aria-hidden="true">&rsaquo;</span>
        </a>
      )}
    </div>

    {trustItems.length > 0 && (
      <ul class="hero-trust">
        {trustItems.map((t) => (
          <li><strong>{t.strong}</strong> {t.label}</li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background-color: var(--color-bg);
    color: var(--color-text);
    padding: 3.5rem 0 4rem;
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    z-index: -2;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      100deg,
      rgba(26, 26, 29, 0.96) 0%,
      rgba(26, 26, 29, 0.9) 30%,
      rgba(26, 26, 29, 0.65) 60%,
      rgba(26, 26, 29, 0.35) 95%
    );
  }

  .hero-inner {
    max-width: 880px;
  }

  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.98;
    margin: 0 0 1.25rem;
    max-width: 18ch;
  }

  .hero h1 :global(.accent) {
    color: var(--color-accent);
    white-space: nowrap;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .hero-call {
    display: inline-flex;
    align-items: center;
    gap: 0.95rem;
    padding: 1rem 1.5rem;
    background-color: var(--color-accent);
    color: var(--color-text);
    border-radius: var(--radius);
    text-decoration: none;
    box-shadow: 0 14px 32px -16px rgba(255, 45, 45, 0.7);
    transition: background-color var(--transition), transform var(--transition), box-shadow var(--transition);
    min-height: 64px;
  }

  .hero-call:hover,
  .hero-call:focus-visible {
    background-color: var(--color-accent-dark);
    color: var(--color-text);
    transform: translateY(-1px);
    box-shadow: 0 18px 38px -16px rgba(255, 45, 45, 0.8);
  }

  .hero-call-icon {
    font-size: 1.6rem;
    line-height: 1;
  }

  .hero-call-stack {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.05;
  }

  .hero-call-stack small {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    opacity: 0.85;
    margin-bottom: 0.25rem;
  }

  .hero-call-stack strong {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.55rem;
    letter-spacing: 0.02em;
  }

  .hero-secondary-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    padding: 1rem 1.5rem;
    background-color: rgba(255, 255, 255, 0.04);
    color: var(--color-text);
    border: 2px solid rgba(255, 255, 255, 0.55);
    border-radius: var(--radius);
    text-decoration: none;
    min-height: 64px;
    transition: background-color var(--transition), border-color var(--transition), color var(--transition), transform var(--transition);
  }

  .hero-secondary-btn:hover,
  .hero-secondary-btn:focus-visible {
    background-color: var(--color-text);
    color: var(--color-text-dark);
    border-color: var(--color-text);
    transform: translateY(-1px);
  }

  .hero-secondary-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.05;
  }

  .hero-secondary-arrow {
    font-size: 1.4rem;
    line-height: 1;
    margin-top: -2px;
    opacity: 0.85;
  }

  .hero-trust {
    list-style: none;
    padding: 0;
    margin: 1.75rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .hero-trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.95rem;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
  }

  .hero-trust strong {
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.01em;
  }

  @media (max-width: 768px) {
    .hero {
      display: block;
      padding: 0 0 2.5rem;
      min-height: auto;
    }
    .hero-bg-img {
      position: static;
      width: 100%;
      height: 240px;
      object-position: center center;
      z-index: 0;
    }
    .hero::before {
      display: none;
    }
    .hero-inner {
      padding-top: 2rem;
    }
    .hero h1 {
      font-size: clamp(2rem, 9vw, 2.8rem);
      max-width: none;
    }
    .hero-eyebrow {
      margin-bottom: 0.85rem;
      font-size: 0.78rem;
    }
    .hero-sub {
      margin-bottom: 1.5rem;
    }
    .hero-call,
    .hero-secondary-btn {
      width: 100%;
      justify-content: center;
    }
    .hero-trust {
      margin-top: 1.5rem;
      gap: 0.5rem;
    }
    .hero-trust li {
      padding: 0.45rem 0.8rem;
      font-size: 0.82rem;
    }
    .hero-trust strong {
      font-size: 0.9rem;
    }
  }
</style>

---
export interface Props {
  trustBar?: string;
  title: string;
  subtitle: string;
  ctaPhone: string;
  ctaQuote?: boolean;
  ctaQuoteHref?: string;
  showStats?: boolean;
  bgImage?: string;
  bgImageAlt?: string;
}

const {
  trustBar = '',
  title,
  subtitle,
  ctaPhone,
  ctaQuote = true,
  ctaQuoteHref = '#quote',
  showStats = true,
  bgImage,
  bgImageAlt = 'Tyre Emergency Ltd service van working on the roadside',
} = Astro.props as Props;

const telHref = `tel:${ctaPhone.replace(/\s+/g, '')}`;
---

<section class="hero" data-has-bg={bgImage ? '' : undefined}>
  {bgImage && (
    <img
      class="hero-bg-img"
      src={bgImage}
      alt={bgImageAlt}
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  )}

  {trustBar && (
    <div class="trust-bar" aria-label="Trust statement">{trustBar}</div>
  )}

  <div class="container hero-inner">
    <h1 set:html={title} />
    <p class="hero-sub">{subtitle}</p>

    <div class="cta-row">
      <a class="btn btn-primary btn-call" href={telHref}>
        <span class="phone-glyph" aria-hidden="true">&#9742;</span>
        Call Now: {ctaPhone}
      </a>
      {ctaQuote && (
        <a class="btn btn-outline" href={ctaQuoteHref}>Get a Quote</a>
      )}
    </div>

    {showStats && (
      <div class="stat-pills hero-stats">
        <span class="stat-pill"><strong>30 min</strong> avg. ETA</span>
        <span class="stat-pill"><strong>478</strong> Five-Star Reviews</span>
        <span class="stat-pill"><strong>24/7</strong> Including Bank Holidays</span>
      </div>
    )}
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <span class="hero-scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-bg);
    color: var(--color-text);
    overflow: hidden;
    isolation: isolate;
    padding: 0 0 5rem;
    min-height: calc(100vh - 72px);
    display: flex;
    flex-direction: column;
  }

  /* Dark gradient overlay — always present */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(900px 600px at 80% 10%, rgba(255, 45, 45, 0.18), transparent 60%),
      radial-gradient(700px 500px at 10% 90%, rgba(255, 45, 45, 0.08), transparent 60%);
    z-index: -1;
  }

  /* Subtle grid texture */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: -1;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  }

  /* Photo sits behind everything */
  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    z-index: -2;
  }

  /* When a photo is present, strengthen the left-side text mask */
  .hero[data-has-bg]::before {
    background:
      linear-gradient(
        100deg,
        rgba(14, 14, 14, 0.98) 0%,
        rgba(14, 14, 14, 0.94) 30%,
        rgba(14, 14, 14, 0.72) 55%,
        rgba(14, 14, 14, 0.35) 75%,
        rgba(14, 14, 14, 0.15) 100%
      ),
      radial-gradient(700px 500px at 10% 90%, rgba(255, 45, 45, 0.06), transparent 60%);
    z-index: -1;
  }

  .trust-bar {
    background-color: var(--color-accent);
    color: var(--color-text);
    text-align: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.7rem 1rem;
  }

  .hero-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding-top: 4rem;
    padding-bottom: 3rem;
    max-width: 980px;
  }

  .hero-inner h1 {
    font-size: clamp(2.6rem, 7.2vw, 5.8rem);
    line-height: 0.95;
    margin-bottom: 1.25rem;
    max-width: 18ch;
  }

  .hero-sub {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-bottom: 2rem;
  }

  .btn-call {
    font-size: 1.2rem;
    padding: 1.1rem 1.8rem;
  }

  .phone-glyph {
    font-size: 1.3rem;
  }

  .hero-stats {
    margin-top: 2rem;
    justify-content: flex-start;
  }

  .hero-stats .stat-pill strong {
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: 1rem;
  }

  .hero-scroll {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 40px;
  }

  .hero-scroll-line {
    display: block;
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, var(--color-accent));
  }

  @media (max-width: 768px) {
    .hero {
      padding-bottom: 3rem;
      min-height: auto;
    }
    .hero-inner {
      padding-top: 2.5rem;
      padding-bottom: 2.5rem;
    }
    .hero-stats {
      justify-content: flex-start;
    }
    .hero-scroll {
      display: none;
    }
    .btn-call {
      font-size: 1.1rem;
      padding: 1rem 1.4rem;
    }
    /* On mobile the photo shows, but centre it so the van is visible */
    .hero-bg-img {
      object-position: center center;
    }
    .hero[data-has-bg]::before {
      background: rgba(14, 14, 14, 0.82);
    }
  }
</style>

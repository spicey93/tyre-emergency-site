---
import ReviewCard from './ReviewCard.astro';
import { reviews, googleRating } from '../data/reviews';

export interface Props {
  /** Optional eyebrow above the heading. Defaults to "Trusted by drivers". */
  eyebrow?: string;
  /** Section heading — one short line. */
  title?: string;
  /** Optional supporting line below the heading. */
  lede?: string;
  /** Background variant — "white" (default) or "light" so the section
      can fit between any two neighbouring sections without colour clashes. */
  variant?: 'white' | 'light';
}

const {
  eyebrow = 'Trusted by drivers',
  title = 'Five stars. Hundreds of drivers rescued.',
  lede = 'A few words from real customers we&rsquo;ve sorted out — on the roadside, on the driveway and in the office car park.',
  variant = 'white',
} = Astro.props as Props;

const sectionClass = variant === 'light' ? 'section section-light' : 'section section-white';
---

<section class={sectionClass}>
  <div class="container">
    <div class="text-center">
      <span class="eyebrow">{eyebrow}</span>
      <h2>{title}</h2>
      <p class="reviews-section-lede" set:html={lede} />
    </div>

    <div
      class="reviews-carousel"
      data-reviews-carousel
      role="region"
      aria-roledescription="carousel"
      aria-label="Customer reviews"
      tabindex="0"
      style={`--slide-count: ${reviews.length};`}
    >
      <div class="reviews-carousel-viewport">
        <ul class="reviews-carousel-track">
          {reviews.map((r, i) => (
            <li
              class="reviews-carousel-slide"
              aria-roledescription="slide"
              aria-label={`${i + 1} of ${reviews.length}`}
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              <ReviewCard name={r.name} location={r.location} text={r.text} rating={r.rating} />
            </li>
          ))}
        </ul>
      </div>

      <div class="reviews-carousel-controls">
        <button
          type="button"
          class="reviews-carousel-arrow"
          data-prev
          aria-label="Previous review"
        >
          <span aria-hidden="true">&#8249;</span>
        </button>
        <ol class="reviews-carousel-dots" aria-label="Review navigation">
          {reviews.map((_, i) => (
            <li>
              <button
                type="button"
                class="reviews-carousel-dot"
                data-goto={i}
                aria-label={`Show review ${i + 1}`}
                aria-current={i === 0 ? 'true' : 'false'}
              ></button>
            </li>
          ))}
        </ol>
        <button
          type="button"
          class="reviews-carousel-arrow"
          data-next
          aria-label="Next review"
        >
          <span aria-hidden="true">&#8250;</span>
        </button>
      </div>
    </div>

    <div class="reviews-section-rating">
      <span class="reviews-section-google" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09 0-.73.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
      </span>
      <span class="reviews-section-rating-text">
        <strong>{googleRating.ratingValue}</strong>
        <span>Rated on Google from {googleRating.reviewCount} reviews</span>
      </span>
      <span class="reviews-section-stars" aria-hidden="true">
        <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span>
      </span>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var carousels = document.querySelectorAll('[data-reviews-carousel]');
    if (!carousels.length) return;

    var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    carousels.forEach(function (root) {
      var track = root.querySelector('.reviews-carousel-track');
      var slides = Array.prototype.slice.call(root.querySelectorAll('.reviews-carousel-slide'));
      var dots = Array.prototype.slice.call(root.querySelectorAll('.reviews-carousel-dot'));
      var prev = root.querySelector('[data-prev]');
      var next = root.querySelector('[data-next]');
      if (!track || slides.length === 0) return;

      var current = 0;
      var count = slides.length;
      var autoMs = 6000;
      var timer = null;

      // Track is N × viewport-width; each slide is 1/N of track. So one
      // step is 100/N percent of the track's width.
      var stepPct = 100 / count;

      function goTo(i) {
        current = ((i % count) + count) % count;
        track.style.transform = 'translateX(' + (-stepPct * current) + '%)';
        slides.forEach(function (s, idx) {
          s.setAttribute('aria-hidden', idx === current ? 'false' : 'true');
        });
        dots.forEach(function (d, idx) {
          d.setAttribute('aria-current', idx === current ? 'true' : 'false');
        });
      }

      function startAuto() {
        if (prefersReduced || count <= 1) return;
        stopAuto();
        timer = setInterval(function () { goTo(current + 1); }, autoMs);
      }
      function stopAuto() {
        if (timer) { clearInterval(timer); timer = null; }
      }
      function resetAuto() {
        if (timer != null) { stopAuto(); startAuto(); }
      }

      if (prev) prev.addEventListener('click', function () { goTo(current - 1); resetAuto(); });
      if (next) next.addEventListener('click', function () { goTo(current + 1); resetAuto(); });
      dots.forEach(function (d, idx) {
        d.addEventListener('click', function () { goTo(idx); resetAuto(); });
      });

      // Arrow keys when carousel has focus
      root.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); resetAuto(); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); resetAuto(); }
      });

      // Swipe support
      var startX = null;
      var startY = null;
      track.addEventListener('touchstart', function (e) {
        var t = e.touches[0];
        startX = t.clientX;
        startY = t.clientY;
      }, { passive: true });
      track.addEventListener('touchend', function (e) {
        if (startX == null) return;
        var t = e.changedTouches[0];
        var dx = t.clientX - startX;
        var dy = t.clientY - startY;
        // Only treat as swipe if mostly horizontal and >50px
        if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
          goTo(current + (dx < 0 ? 1 : -1));
          resetAuto();
        }
        startX = null;
        startY = null;
      });

      // Pause auto-advance on hover/focus, resume on leave/blur
      root.addEventListener('mouseenter', stopAuto);
      root.addEventListener('mouseleave', startAuto);
      root.addEventListener('focusin', stopAuto);
      root.addEventListener('focusout', function (e) {
        // Only restart if focus actually leaves the carousel
        if (!root.contains(e.relatedTarget)) startAuto();
      });

      // Pause when tab not visible
      document.addEventListener('visibilitychange', function () {
        if (document.hidden) stopAuto();
        else startAuto();
      });

      // Init
      goTo(0);
      startAuto();
    });
  })();
</script>

<style>
  .reviews-section-lede {
    max-width: 60ch;
    margin: 0 auto 2.5rem;
    font-size: 1.1rem;
    color: inherit;
    opacity: 0.85;
  }

  /* ---------- Carousel ---------- */

  .reviews-carousel {
    position: relative;
    max-width: 720px;
    margin: 0 auto 2rem;
    outline: none;
  }

  .reviews-carousel:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 6px;
    border-radius: var(--radius);
  }

  .reviews-carousel-viewport {
    overflow: hidden;
    border-radius: var(--radius);
  }

  .reviews-carousel-track {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    /* Track is N viewports wide so each slide can be 100% of the viewport
       (= 1/N of the track). Lets us translate by a fixed -100/N% per step. */
    width: calc(100% * var(--slide-count, 1));
    transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
    align-items: stretch;
  }

  @media (prefers-reduced-motion: reduce) {
    .reviews-carousel-track {
      transition: none;
    }
  }

  .reviews-carousel-slide {
    flex: 0 0 calc(100% / var(--slide-count, 1));
    min-width: 0;
    padding: 0.25rem;
    box-sizing: border-box;
  }

  .reviews-carousel-slide[aria-hidden="true"] {
    /* keep in flow but don't intercept input */
    pointer-events: none;
  }

  /* ---------- Controls ---------- */

  .reviews-carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .reviews-carousel-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid var(--color-border-light);
    background-color: var(--color-bg-white);
    color: var(--color-text-dark);
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color 160ms ease-out, color 160ms ease-out, transform 160ms ease-out;
    flex-shrink: 0;
  }

  .reviews-carousel-arrow:hover,
  .reviews-carousel-arrow:focus-visible {
    border-color: var(--color-text-dark);
    color: var(--color-text-dark);
  }

  .reviews-carousel-arrow:active {
    transform: scale(0.94);
  }

  .reviews-carousel-arrow span {
    /* nudge the chevron up a hair so it sits visually centred */
    transform: translateY(-2px);
    display: inline-block;
  }

  .section-light .reviews-carousel-arrow,
  .section-white .reviews-carousel-arrow {
    background-color: var(--color-bg-white);
  }

  .reviews-carousel-dots {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.55rem;
    align-items: center;
  }

  .reviews-carousel-dot {
    width: 9px;
    height: 9px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background-color: rgba(0, 0, 0, 0.18);
    cursor: pointer;
    transition: background-color 160ms ease-out, transform 160ms ease-out;
  }

  .reviews-carousel-dot:hover {
    background-color: rgba(0, 0, 0, 0.32);
  }

  .reviews-carousel-dot[aria-current="true"] {
    background-color: var(--color-accent);
    transform: scale(1.35);
  }

  /* ---------- Google rating block ---------- */

  .reviews-section-rating {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    padding: 1.1rem 1.5rem;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    max-width: 540px;
    margin: 0 auto;
  }

  .reviews-section-rating-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--color-text-dark);
  }

  .reviews-section-rating-text strong {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--color-text-dark);
  }

  .reviews-section-stars {
    color: var(--color-star);
    letter-spacing: 0.1em;
    font-size: 1.1rem;
  }
</style>

---
// Slim trust strip under the navbar. Intentionally not a phone CTA —
// the hero, sticky call button and header already cover that. This
// strip just reassures the visitor before they've started reading.
---

<div class="site-banner" role="presentation">
  <span class="site-banner-text">
    <span class="site-banner-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
    <span><strong>478</strong> Google reviews</span>
    <span class="site-banner-sep" aria-hidden="true">·</span>
    <span>REACT licensed &amp; fully insured</span>
    <span class="site-banner-sep" aria-hidden="true">·</span>
    <span>Mobile tyre fitting across Nottinghamshire</span>
  </span>
</div>

<style>
  .site-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 1rem;
    background-color: var(--color-bg-white);
    color: var(--color-text-dark);
    border-bottom: 1px solid var(--color-border-light);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.3;
  }

  .site-banner-text {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .site-banner-stars {
    color: var(--color-star);
    letter-spacing: 0.05em;
    font-size: 0.95rem;
  }

  .site-banner strong {
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .site-banner-sep {
    opacity: 0.45;
  }

  @media (max-width: 720px) {
    .site-banner {
      padding: 0.5rem 0.85rem;
      font-size: 0.78rem;
      letter-spacing: 0.04em;
    }
    .site-banner-text > *:nth-child(n+3) {
      display: none;
    }
  }
</style>

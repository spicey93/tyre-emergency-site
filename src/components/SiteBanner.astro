---
// Slim promo strip under the navbar.
---

<div class="site-banner" role="presentation">
  <span class="site-banner-text">
    <span class="site-banner-tag" aria-hidden="true">%</span>
    Save 10% on 2+ tyres with code
    <strong class="site-banner-code">2TYRES10</strong>
  </span>
</div>

<style>
  .site-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1rem;
    background:
      linear-gradient(90deg, var(--color-accent-dark) 0%, var(--color-accent) 50%, var(--color-accent-dark) 100%);
    color: var(--color-text);
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    line-height: 1.3;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
    position: relative;
    z-index: 1;
  }

  .site-banner-text {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .site-banner-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background-color: var(--color-text);
    color: var(--color-accent-dark);
    font-weight: 900;
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: 0;
  }

  .site-banner-code {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    background-color: var(--color-text);
    color: var(--color-accent-dark);
    border-radius: var(--radius);
    font-weight: 900;
    letter-spacing: 0.12em;
    font-size: 1.05rem;
    line-height: 1.1;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
    animation: site-banner-pulse 1.4s ease-in-out 1s 2;
    transform-origin: center;
  }

  @keyframes site-banner-pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25); }
    50% { transform: scale(1.07); box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35); }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-banner-code { animation: none; }
  }

  @media (max-width: 720px) {
    .site-banner {
      padding: 0.7rem 0.85rem;
      font-size: 0.86rem;
      letter-spacing: 0.06em;
    }
    .site-banner-code {
      font-size: 0.92rem;
      padding: 0.24rem 0.6rem;
    }
    .site-banner-tag {
      width: 1.3rem;
      height: 1.3rem;
      font-size: 0.85rem;
    }
  }
</style>

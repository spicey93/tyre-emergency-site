---
// Slim promo strip under the navbar.
---

<div class="site-banner" role="presentation">
  <span class="site-banner-text">
    Save 10% on 2+ tyres with code <strong class="site-banner-code">2TYRES10</strong>
  </span>
</div>

<style>
  .site-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.45rem 1rem;
    background-color: var(--color-accent);
    color: var(--color-text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.88rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.25;
  }

  .site-banner-text {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .site-banner-code {
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: 0.12em;
    color: var(--color-text);
    border: 1.5px solid rgba(255, 255, 255, 0.65);
    border-radius: 2px;
    padding: 0.05rem 0.45rem;
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .site-banner {
      padding: 0.4rem 0.75rem;
      font-size: 0.78rem;
      letter-spacing: 0.05em;
    }
    .site-banner-code {
      font-size: 0.82rem;
      padding: 0.03rem 0.4rem;
    }
  }
</style>

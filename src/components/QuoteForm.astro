---
export interface Props {
  formName?: string;
  intro?: string;
}

const {
  formName = 'quote-request',
  intro = 'Not an emergency? Book ahead or get a price for planned mobile tyre fitting.',
} = Astro.props as Props;

const services = [
  'Emergency Tyre Replacement',
  'Mobile Tyre Fitting',
  'Mobile Caravan Tyre Fitting',
  'Mobile Tyre Repair',
  'Locking Wheel Nut Removal',
  'TPMS Sensor Replacement',
];
---

<div class="quote-form-wrap">
  <p class="quote-intro">{intro}</p>

  <form
    class="quote-form"
    name={formName}
    method="POST"
    action="/thank-you/"
    data-netlify="true"
    data-netlify-honeypot="bot-field"
    netlify
  >
    <input type="hidden" name="form-name" value={formName} />
    <p class="honeypot-field">
      <label>
        Do not fill this out if you are human
        <input name="bot-field" tabindex="-1" autocomplete="off" />
      </label>
    </p>

    <div class="field-grid">
      <div class="field">
        <label for="qf-name">Full name</label>
        <input id="qf-name" name="name" type="text" required autocomplete="name" />
      </div>

      <div class="field">
        <label for="qf-phone">Phone number</label>
        <input id="qf-phone" name="phone" type="tel" required autocomplete="tel" />
      </div>

      <div class="field">
        <label for="qf-email">Email</label>
        <input id="qf-email" name="email" type="email" required autocomplete="email" />
      </div>

      <div class="field">
        <label for="qf-reg">Vehicle registration</label>
        <input id="qf-reg" name="registration" type="text" autocomplete="off" placeholder="e.g. AB12 CDE" />
      </div>

      <div class="field">
        <label for="qf-service">Service required</label>
        <select id="qf-service" name="service" required>
          <option value="">Choose a service</option>
          {services.map((s) => (
            <option value={s}>{s}</option>
          ))}
        </select>
      </div>

      <div class="field">
        <label for="qf-location">Location / postcode</label>
        <input id="qf-location" name="location" type="text" required autocomplete="postal-code" placeholder="e.g. NG22 8GA" />
      </div>

      <div class="field field-full">
        <label for="qf-message">Message</label>
        <textarea id="qf-message" name="message" rows="4" placeholder="Tell us what's happened, the tyre size if known, and the best time to reach you."></textarea>
      </div>
    </div>

    <button type="submit" class="btn btn-primary btn-block">Request a Quote</button>

    <p class="quote-disclaimer">
      For emergencies, please call <a href="tel:01623325123"><strong>01623 325 123</strong></a> directly &mdash; do not use this form.
    </p>
  </form>
</div>

<style>
  .quote-form-wrap {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    padding: 2.25rem;
    border-radius: var(--radius);
  }

  .quote-intro {
    color: var(--color-text-muted-dark);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .field-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
    margin-bottom: 1.5rem;
  }

  .field-full {
    grid-column: 1 / -1;
  }

  .field {
    display: flex;
    flex-direction: column;
  }

  .field label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-dark);
    margin-bottom: 0.45rem;
  }

  .field input,
  .field select,
  .field textarea {
    padding: 0.85rem 0.95rem;
    background-color: var(--color-bg-white);
    color: var(--color-text-dark);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius);
    font-size: 1rem;
    transition: border-color var(--transition), box-shadow var(--transition);
    width: 100%;
    font-family: var(--font-body);
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(255, 45, 45, 0.18);
  }

  .field textarea {
    resize: vertical;
    min-height: 110px;
  }

  .quote-disclaimer {
    margin-top: 1.25rem;
    margin-bottom: 0;
    text-align: center;
    color: var(--color-text-muted-dark);
    font-size: 0.9rem;
  }

  .quote-disclaimer a {
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .quote-form-wrap {
      padding: 1.5rem;
    }
    .field-grid {
      grid-template-columns: 1fr;
      gap: 0.95rem;
    }
  }
</style>

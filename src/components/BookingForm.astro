---
export interface Props {
  variant?: 'dark' | 'light';
  buttonLabel?: string;
}

const { variant = 'dark', buttonLabel = 'Book online' } = Astro.props as Props;
const wrapperClass = variant === 'light' ? 'booking-form booking-form-light' : 'booking-form';
const buttonClass = variant === 'light' ? 'btn btn-outline-dark' : 'btn btn-outline';
---

<form
  class={wrapperClass}
  method="GET"
  action="https://garage-bookings.com/"
  target="_blank"
  rel="noopener"
>
  <input type="hidden" name="clientID" value="537" />
  <input
    class="booking-vrm"
    name="vrm"
    type="text"
    placeholder="Enter your VRM"
    required
    autocomplete="off"
    aria-label="Vehicle registration"
  />
  <button type="submit" class={buttonClass}>{buttonLabel}</button>
</form>

<style>
  .booking-form {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .booking-vrm {
    flex: 1 1 180px;
    min-width: 0;
    padding: 0 1rem;
    background-color: rgba(255, 255, 255, 0.08);
    border: 2px solid var(--color-text);
    border-radius: var(--radius);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    min-height: 52px;
    max-width: 220px;
    transition: border-color var(--transition), background-color var(--transition);
  }

  .booking-vrm::placeholder {
    color: rgba(255, 255, 255, 0.55);
    text-transform: none;
    letter-spacing: 0;
  }

  .booking-vrm:focus {
    outline: none;
    border-color: var(--color-accent);
    background-color: rgba(255, 255, 255, 0.12);
  }

  .booking-form-light .booking-vrm {
    background-color: var(--color-bg-white);
    border-color: var(--color-text-dark);
    color: var(--color-text-dark);
  }

  .booking-form-light .booking-vrm::placeholder {
    color: var(--color-text-muted-dark);
  }

  .booking-form-light .booking-vrm:focus {
    border-color: var(--color-accent);
    background-color: var(--color-bg-white);
  }

  .booking-form .btn {
    flex: 0 0 auto;
  }

  @media (max-width: 600px) {
    .booking-form {
      flex-wrap: nowrap;
      gap: 0.5rem;
    }
    .booking-vrm {
      flex: 1 1 auto;
      max-width: none;
      min-height: 44px;
      padding: 0 0.75rem;
      font-size: 0.95rem;
      letter-spacing: 0.04em;
      border-width: 1px;
    }
    .booking-form .btn {
      flex: 0 0 auto;
      min-height: 44px;
      padding: 0.65rem 1rem;
      font-size: 0.95rem;
    }
  }
</style>
